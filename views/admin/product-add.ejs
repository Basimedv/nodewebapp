<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Product - COLINGUEST</title>
  <link href="https://fonts.googleapis.com/css2?family=Bellefair&family=Outfit:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css" rel="stylesheet" />
  <style>
    body { font-family: 'Outfit', sans-serif; background: #f5f7fa; min-height: 100vh; }
    .navbar { background: white; padding: 15px 30px; position: fixed; top: 0; left: 0; right: 0; z-index: 1000; box-shadow: 0 2px 10px rgba(0,0,0,.08); }
    .brand-name { font-family: 'Bellefair'; font-size: 28px; color: #192430; text-decoration: none; }
    .sidebar { width: 250px; background: #f9f9f9; padding: 20px 0; position: fixed; top: 60px; bottom: 0; left: 0; overflow-y: auto; }
    .sidebar a { display: flex; align-items: center; padding: 15px 30px; color: #192430; text-decoration: none; border-radius: 15px; }
    .sidebar a.active { background: #3b6da1; color: white; }
    .sidebar a i { margin-right: 12px; }
    .main-content { margin-left: 250px; padding: 80px 30px 30px; }
    .card { border: none; box-shadow: 0 2px 10px rgba(0,0,0,.06); }
    .btn-primary { background: #0202a1; border-color: #1900ba; }
    .btn-primary:hover { background: #0b5ed7; border-color: #0b5ed7; }

    /* Validation */
    .error-message { color: #dc3545; font-size: 0.8rem; margin-top: 4px; display: none; }
    .error-message.show { display: block; }
    .form-control.is-invalid,
    .form-select.is-invalid { border-color: #dc3545; box-shadow: 0 0 0 0.2rem rgba(220,53,69,.15); }
    .form-control.is-valid,
    .form-select.is-valid { border-color: #198754; }

    /* Image Upload */
    .image-upload-slot { position: relative; min-height: 250px; border-radius: 8px; overflow: hidden; }
    .image-upload-dropzone {
      border: 2px dashed #d0d5dd; border-radius: 8px; min-height: 250px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      cursor: pointer; transition: all 0.3s ease; background: #f9fafb; padding: 20px;
    }
    .image-upload-dropzone:hover { border-color: #0d6efd; background: #f0f7ff; transform: translateY(-2px); }
    .image-upload-dropzone.drag-over { border-color: #0d6efd; background: #e7f1ff; }
    .image-upload-dropzone.has-error { border-color: #dc3545; background: #fff5f5; }
    .image-preview { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 8px; overflow: hidden; background: #fff; border: 2px solid #e5e7eb; }
    .image-preview .img-wrapper { position: relative; width: 100%; height: 250px; display: flex; align-items: center; justify-content: center; background: #f9fafb; }
    .image-preview .img-fit { max-width: 100%; max-height: 100%; object-fit: contain; }
    .img-badge { position: absolute; top: 8px; left: 8px; padding: 4px 12px; font-size: 0.7rem; border-radius: 4px; font-weight: 600; color: white; z-index: 10; }
    .badge-success { background: #10b981; }
    .badge-info { background: #3b82f6; }
    .remove-image-btn { position: absolute; top: 8px; right: 8px; background: #ef4444; color: white; border: none; border-radius: 50%; width: 32px; height: 32px; cursor: pointer; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; z-index: 10; transition: all 0.2s; }
    .remove-image-btn:hover { background: #dc2626; transform: scale(1.1); }
    .recrop-image-btn { position: absolute; bottom: 8px; right: 8px; background: #3b82f6; color: white; border: none; border-radius: 6px; padding: 6px 12px; cursor: pointer; font-size: 0.8rem; font-weight: 500; z-index: 10; transition: all 0.2s; }
    .recrop-image-btn:hover { background: #2563eb; }
    .img-container { max-height: 70vh; overflow: hidden; }
    .img-container img { max-width: 100%; display: block; }
    .aspect-ratio-btn.active { background-color: #0d6efd; color: white; border-color: #0d6efd; }

    /* Stock */
    .stock-input.is-invalid { border-color: #dc3545; }
    #stock-error.show { display: block; }

    /* Price hint */
    .price-hint { font-size: 0.75rem; color: #6c757d; margin-top: 3px; }
    .price-hint.warn { color: #e67e22; }
    .price-hint.danger { color: #dc3545; }
  </style>
</head>

<body>
  <nav class="navbar">
    <a class="brand-name" href="/admin/products">COLINGUEST</a>
  </nav>

  <div class="sidebar d-none d-lg-block">
    <a href="/admin/dashboard"><i class="bi bi-grid"></i> Dashboard</a>
    <a href="/admin/categories"><i class="bi bi-tag"></i> Categories</a>
    <a href="/admin/products" class="active"><i class="bi bi-box"></i> Products</a>
    <a href="/admin/customers"><i class="bi bi-people"></i> Customers</a>
    <a href="/admin/orders"><i class="bi bi-cart"></i> Orders</a>
    <a href="/admin/coupons"><i class="bi bi-ticket"></i> Coupons</a>
    <a href="/admin/sales-report"><i class="bi bi-bar-chart"></i> Sales Report</a>
    <a href="/admin/wallet-management"><i class="bi bi-credit-card"></i> Wallet</a>
    <a href="/admin/logout"><i class="bi bi-box-arrow-right"></i> Sign Out</a>
  </div>

  <div class="main-content">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h2 class="mb-1" style="color:#1a1b1c;">Add New Product</h2>
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/admin/products">Products</a></li>
            <li class="breadcrumb-item active">Add Product</li>
          </ol>
        </nav>
      </div>
      <a href="/admin/products" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
      </a>
    </div>

    <div class="card">
      <div class="card-body p-4">
        <form id="addProductForm" enctype="multipart/form-data" novalidate>
          <div class="row">
            <div class="col-12">

              <!-- Product Name -->
              <div class="mb-3">
                <label class="form-label" for="productName">
                  Product Name <span class="text-danger">*</span>
                </label>
                <input type="text" class="form-control" id="productName" name="productName"
                  placeholder="Enter product name (3-100 characters)" maxlength="100">
                <div id="productName-error" class="error-message"></div>
              </div>

              <!-- Category -->
              <div class="mb-3">
                <label class="form-label" for="category">
                  Category <span class="text-danger">*</span>
                </label>
                <select id="category" name="category" class="form-select">
                  <option value="">Select Category</option>
                  <% for(let i = 0; i < cat.length; i++) { %>
                    <option value="<%= cat[i]._id %>"><%= cat[i].name %></option>
                  <% } %>
                </select>
                <div id="category-error" class="error-message"></div>
              </div>

              <!-- Description -->
              <div class="mb-3">
                <label class="form-label" for="description">Description</label>
                <textarea class="form-control" id="description" name="description" rows="4"
                  placeholder="Write product description (optional, max 1000 characters)"
                  maxlength="1000"></textarea>
                <div class="d-flex justify-content-between">
                  <div id="description-error" class="error-message"></div>
                  <small id="descCharCount" class="text-muted mt-1">0 / 1000</small>
                </div>
              </div>

              <!-- Price Row -->
              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <label class="form-label" for="regularPrice">
                    Regular Price (₹) <span class="text-danger">*</span>
                  </label>
                  <input type="number" class="form-control" id="regularPrice" name="regularPrice"
                    placeholder="0.00" min="1" step="0.01">
                  <div id="regularPrice-error" class="error-message"></div>
                </div>
                <div class="col-md-4">
                  <label class="form-label" for="salePrice">
                    Sale Price (₹) <span class="text-muted small">(optional)</span>
                  </label>
                  <input type="number" class="form-control" id="salePrice" name="salePrice"
                    placeholder="0.00" min="0" step="0.01">
                  <div id="salePrice-error" class="error-message"></div>
                  <div id="salePriceHint" class="price-hint"></div>
                </div>
              </div>

              <!-- Stock by Size -->
              <div class="mb-3">
                <label class="form-label">Stock by Size <span class="text-danger">*</span></label>
                <div class="row">
                  <% ['S', 'M', 'L', 'XL', 'XXL'].forEach(size => { %>
                    <div class="col-md-2 mb-2">
                      <label class="form-label small fw-semibold"><%= size %></label>
                      <input type="number" name="stock_<%= size %>" id="stock_<%= size %>"
                        class="form-control" min="0" max="9999" value="0">
                    </div>
                  <% }) %>
                </div>
                <div class="alert alert-info mt-3 mb-1 py-2">
                  <i class="bi bi-info-circle me-2"></i>
                  <strong>Total Stock:</strong>
                  <span id="totalStock" class="fs-6 fw-bold">0</span> units
                </div>
                <div id="stock-error" class="error-message"></div>
              </div>

              <input type="hidden" id="size-array" name="size">

              <!-- Status -->
              <div class="mb-4">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                  <option value="Available" selected>Available</option>
                  <option value="Out of Stock">Out of Stock</option>
                  <option value="Discontinued">Discontinued</option>
                </select>
              </div>

              <!-- Product Images -->
              <div class="mb-4">
                <label class="form-label fw-bold">
                  Product Images <span class="text-danger">*</span>
                </label>
                <p class="text-muted small">
                  Upload up to 3 images. At least 1 required. (JPG, PNG, WebP — max 5MB each)
                </p>
                <div class="row g-3">
                  <% for (let i = 0; i < 3; i++) { %>
                    <div class="col-md-4">
                      <div class="image-upload-slot" data-slot="<%= i %>">
                        <div class="image-upload-dropzone">
                          <i class="bi bi-cloud-upload" style="font-size: 2.5rem; color: #bbb;"></i>
                          <p class="mb-0 mt-2 small text-muted">Click or drag image here</p>
                          <p class="mb-0 small text-muted" style="font-size:0.72rem;">JPG, PNG, WebP</p>
                        </div>
                        <div class="image-preview d-none"></div>
                      </div>
                    </div>
                  <% } %>
                </div>
                <div id="imageError" class="error-message mt-2"></div>
              </div>

              <hr class="my-4">
              <div class="d-flex justify-content-between align-items-center">
                <a href="/admin/products" class="btn btn-outline-secondary">
                  <i class="bi bi-x-circle me-1"></i> Cancel
                </a>
                <button type="submit" id="submitBtn" class="btn btn-primary btn-lg px-5">
                  <i class="bi bi-plus-circle me-2"></i> Add Product
                </button>
              </div>

            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Crop Modal -->
  <div class="modal fade" id="cropModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
      <div class="modal-content border-0 shadow-lg">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title fw-bold"><i class="bi bi-crop me-2"></i>Crop Your Image</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4">
          <div class="row">
            <div class="col-md-9">
              <div class="img-container rounded overflow-hidden bg-light mb-3" style="max-height:500px;">
                <img id="imageToCrop" src="" alt="Crop" class="img-fluid" style="max-height:500px; object-fit:contain;">
              </div>
              <div class="d-flex flex-wrap gap-2 justify-content-center">
                <div class="btn-group">
                  <button type="button" class="btn btn-outline-secondary btn-sm" id="rotateLeft"><i class="bi bi-arrow-counterclockwise"></i></button>
                  <button type="button" class="btn btn-outline-secondary btn-sm" id="rotateRight"><i class="bi bi-arrow-clockwise"></i></button>
                </div>
                <div class="btn-group">
                  <button type="button" class="btn btn-outline-secondary btn-sm" id="flipH"><i class="bi bi-arrow-left-right"></i></button>
                  <button type="button" class="btn btn-outline-secondary btn-sm" id="flipV"><i class="bi bi-arrow-down-up"></i></button>
                </div>
                <div class="btn-group">
                  <button type="button" class="btn btn-outline-secondary btn-sm" id="zoomIn"><i class="bi bi-zoom-in"></i></button>
                  <button type="button" class="btn btn-outline-secondary btn-sm" id="zoomOut"><i class="bi bi-zoom-out"></i></button>
                  <button type="button" class="btn btn-outline-secondary btn-sm" id="resetZoom"><i class="bi bi-arrow-clockwise"></i></button>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="mb-3">
                <h6 class="fw-bold mb-2">Preview</h6>
                <div id="cropPreview" class="border rounded" style="width:100%; height:200px; overflow:hidden; background:#f8f9fa;"></div>
              </div>
              <div class="mb-3">
                <h6 class="fw-bold mb-2">Aspect Ratio</h6>
                <div class="btn-group-vertical w-100">
                  <button type="button" class="btn btn-sm btn-outline-primary active aspect-ratio-btn" data-ratio="1">Square (1:1)</button>
                  <button type="button" class="btn btn-sm btn-outline-primary aspect-ratio-btn" data-ratio="1.333">Landscape (4:3)</button>
                  <button type="button" class="btn btn-sm btn-outline-primary aspect-ratio-btn" data-ratio="0">Free</button>
                </div>
              </div>
              <div class="alert alert-info small mb-0">
                <i class="bi bi-info-circle me-1"></i>
                <strong>Tip:</strong> Use mouse wheel to zoom.
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer border-0 justify-content-between">
          <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
          <div>
            <button type="button" class="btn btn-secondary px-4 me-2" id="skipCropButton">Skip Crop</button>
            <button type="button" class="btn btn-primary px-4 fw-semibold" id="cropButton">
              <i class="bi bi-crop me-1"></i>Crop & Save
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
  document.addEventListener('DOMContentLoaded', function () {

    // ── state ──
    let cropper = null;
    let currentFile = null;
    let currentSlotNumber = null;
    let selectedFiles = {};
    let scaleX = 1;
    let scaleY = 1;

    // ══════════════════════════════════════════
    // VALIDATION HELPERS
    // ══════════════════════════════════════════
    function showError(fieldId, msg) {
      const err = document.getElementById(`${fieldId}-error`);
      const inp = document.getElementById(fieldId);
      if (err) { err.textContent = msg; err.classList.add('show'); }
      if (inp) inp.classList.add('is-invalid');
    }

    function clearError(fieldId) {
      const err = document.getElementById(`${fieldId}-error`);
      const inp = document.getElementById(fieldId);
      if (err) { err.textContent = ''; err.classList.remove('show'); }
      if (inp) inp.classList.remove('is-invalid');
    }

    function markValid(fieldId) {
      const inp = document.getElementById(fieldId);
      if (inp) { inp.classList.remove('is-invalid'); inp.classList.add('is-valid'); }
    }

    // validate all fields — returns true if valid
    function validateForm() {
      let valid = true;

      // Product Name
      const name = document.getElementById('productName').value.trim();
      if (!name) {
        showError('productName', 'Product name is required.'); valid = false;
      } else if (name.length < 3) {
        showError('productName', 'Product name must be at least 3 characters.'); valid = false;
      } else if (name.length > 100) {
        showError('productName', 'Product name must not exceed 100 characters.'); valid = false;
      } else {
        clearError('productName'); markValid('productName');
      }

      // Category
      const cat = document.getElementById('category').value;
      if (!cat) {
        showError('category', 'Please select a category.'); valid = false;
      } else {
        clearError('category'); markValid('category');
      }

      // Regular Price
      const regPrice = parseFloat(document.getElementById('regularPrice').value);
      if (!document.getElementById('regularPrice').value || isNaN(regPrice) || regPrice <= 0) {
        showError('regularPrice', 'Please enter a valid regular price greater than 0.'); valid = false;
      } else {
        clearError('regularPrice'); markValid('regularPrice');
      }

      // Sale Price
      const salePriceVal = document.getElementById('salePrice').value;
      if (salePriceVal) {
        const salePrice = parseFloat(salePriceVal);
        if (isNaN(salePrice) || salePrice < 0) {
          showError('salePrice', 'Sale price must be a positive number.'); valid = false;
        } else if (!isNaN(regPrice) && regPrice > 0 && salePrice >= regPrice) {
          showError('salePrice', 'Sale price must be less than regular price (₹' + regPrice.toFixed(2) + ').'); valid = false;
        } else if (salePrice === 0) {
          showError('salePrice', 'Sale price must be greater than 0 if entered.'); valid = false;
        } else {
          clearError('salePrice'); markValid('salePrice');
        }
      } else {
        clearError('salePrice');
        document.getElementById('salePrice').classList.remove('is-invalid', 'is-valid');
      }

      // Stock
      const sizeArray = JSON.parse(document.getElementById('size-array').value || '[]');
      const stockErr = document.getElementById('stock-error');
      if (sizeArray.length === 0) {
        stockErr.textContent = 'Please add stock for at least one size.';
        stockErr.classList.add('show');
        // highlight all zero stock inputs
        ['S','M','L','XL','XXL'].forEach(s => {
          const inp = document.getElementById(`stock_${s}`);
          if (inp && (parseInt(inp.value) || 0) === 0) inp.classList.add('stock-input', 'is-invalid');
        });
        valid = false;
      } else {
        stockErr.textContent = ''; stockErr.classList.remove('show');
        ['S','M','L','XL','XXL'].forEach(s => {
          document.getElementById(`stock_${s}`)?.classList.remove('is-invalid');
        });
      }

      // Images
      const imgErr = document.getElementById('imageError');
      if (Object.keys(selectedFiles).length === 0) {
        imgErr.textContent = 'Please upload at least one product image.';
        imgErr.classList.add('show');
        document.querySelectorAll('.image-upload-dropzone').forEach(d => d.classList.add('has-error'));
        valid = false;
      } else {
        imgErr.textContent = ''; imgErr.classList.remove('show');
        document.querySelectorAll('.image-upload-dropzone').forEach(d => d.classList.remove('has-error'));
      }

      return valid;
    }

    // ══════════════════════════════════════════
    // LIVE VALIDATION
    // ══════════════════════════════════════════

    // Product name — live
    document.getElementById('productName').addEventListener('input', function () {
      const v = this.value.trim();
      if (!v) { showError('productName', 'Product name is required.'); return; }
      if (v.length < 3) { showError('productName', 'At least 3 characters required.'); return; }
      if (v.length > 100) { showError('productName', 'Max 100 characters allowed.'); return; }
      clearError('productName'); markValid('productName');
    });

    // Category — live
    document.getElementById('category').addEventListener('change', function () {
      if (this.value) { clearError('category'); markValid('category'); }
      else showError('category', 'Please select a category.');
    });

    // Description char counter
    document.getElementById('description').addEventListener('input', function () {
      document.getElementById('descCharCount').textContent = `${this.value.length} / 1000`;
    });

    // Regular Price — live
    document.getElementById('regularPrice').addEventListener('input', function () {
      const v = parseFloat(this.value);
      if (!this.value || isNaN(v) || v <= 0) {
        showError('regularPrice', 'Enter a valid price greater than 0.');
      } else {
        clearError('regularPrice'); markValid('regularPrice');
      }
      // re-validate sale price if already filled
      const sp = document.getElementById('salePrice').value;
      if (sp) validateSalePrice(parseFloat(sp), v);
    });

    // Sale Price — live
    document.getElementById('salePrice').addEventListener('input', function () {
      const sp = parseFloat(this.value);
      const rp = parseFloat(document.getElementById('regularPrice').value);
      if (!this.value) {
        clearError('salePrice');
        this.classList.remove('is-invalid', 'is-valid');
        document.getElementById('salePriceHint').textContent = '';
        return;
      }
      validateSalePrice(sp, rp);
    });

    function validateSalePrice(sp, rp) {
      const hint = document.getElementById('salePriceHint');
      if (isNaN(sp) || sp < 0) {
        showError('salePrice', 'Sale price must be a positive number.');
        hint.textContent = ''; return;
      }
      if (sp === 0) {
        showError('salePrice', 'Sale price must be greater than 0 if entered.');
        hint.textContent = ''; return;
      }
      if (!isNaN(rp) && rp > 0 && sp >= rp) {
        showError('salePrice', `Sale price must be less than regular price (₹${rp.toFixed(2)}).`);
        hint.textContent = ''; return;
      }
      clearError('salePrice');
      markValid('salePrice');
      if (!isNaN(rp) && rp > 0 && sp > 0 && sp < rp) {
        const pct = Math.round((rp - sp) / rp * 100);
        hint.textContent = `${pct}% discount applied`;
        hint.className = 'price-hint';
      } else {
        hint.textContent = '';
      }
    }

    // Stock inputs — live
    ['S','M','L','XL','XXL'].forEach(size => {
      const inp = document.getElementById(`stock_${size}`);
      if (!inp) return;
      inp.addEventListener('input', function () {
        const v = parseInt(this.value) || 0;
        if (v < 0) { this.value = 0; }
        if (v > 9999) { this.value = 9999; }
        this.classList.remove('is-invalid');
        updateTotal();
      });
    });

    // ══════════════════════════════════════════
    // STOCK TOTAL
    // ══════════════════════════════════════════
    function updateTotal() {
      const sizes = ['S','M','L','XL','XXL'];
      let total = 0;
      const available = [];
      sizes.forEach(s => {
        const v = parseInt(document.getElementById(`stock_${s}`)?.value) || 0;
        if (v > 0) { total += v; available.push(s); }
      });
      document.getElementById('totalStock').textContent = total;
      document.getElementById('size-array').value = JSON.stringify(available);

      const stockErr = document.getElementById('stock-error');
      if (total > 0) { stockErr.textContent = ''; stockErr.classList.remove('show'); }
    }
    updateTotal();

    // ══════════════════════════════════════════
    // IMAGE UPLOAD & CROP
    // ══════════════════════════════════════════
    document.querySelectorAll('.image-upload-slot').forEach(slot => setupImageSlot(slot));

    function setupImageSlot(slot) {
      const slotNumber = slot.dataset.slot;
      const dropzone   = slot.querySelector('.image-upload-dropzone');
      const preview    = slot.querySelector('.image-preview');

      const input = document.createElement('input');
      input.type = 'file';
      input.accept = 'image/jpeg,image/jpg,image/png,image/webp';
      input.style.display = 'none';
      slot.appendChild(input);

      dropzone.addEventListener('click', (e) => { e.preventDefault(); input.click(); });

      input.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;
        if (!file.type.startsWith('image/')) {
          Swal.fire({ icon:'error', title:'Invalid File', text:'Please select a JPG, PNG, or WebP image.' });
          return;
        }
        if (file.size > 5 * 1024 * 1024) {
          Swal.fire({ icon:'error', title:'File Too Large', text:'Image must be smaller than 5MB.' });
          return;
        }
        currentFile = file; currentSlotNumber = slotNumber;
        openCropModal(file, slotNumber);
      });

      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault(); dropzone.classList.add('drag-over');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag-over'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault(); dropzone.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (!file || !file.type.startsWith('image/')) {
          Swal.fire({ icon:'error', title:'Invalid File', text:'Please drop a valid image file.' });
          return;
        }
        if (file.size > 5 * 1024 * 1024) {
          Swal.fire({ icon:'error', title:'File Too Large', text:'Image must be smaller than 5MB.' });
          return;
        }
        currentFile = file; currentSlotNumber = slotNumber;
        const dt = new DataTransfer(); dt.items.add(file); input.files = dt.files;
        openCropModal(file, slotNumber);
      });
    }

    function openCropModal(file, slotNumber) {
      const reader = new FileReader();
      reader.onload = e => {
        const img = document.getElementById('imageToCrop');
        img.src = e.target.result;
        img.dataset.slotNumber = slotNumber;
        img.dataset.fileName   = file.name;
        const modal = new bootstrap.Modal(document.getElementById('cropModal'));
        modal.show();
        document.getElementById('cropModal').addEventListener('shown.bs.modal', initializeCropper, { once: true });
      };
      reader.readAsDataURL(file);
    }

    function initializeCropper() {
      if (cropper) cropper.destroy();
      scaleX = 1; scaleY = 1;
      cropper = new Cropper(document.getElementById('imageToCrop'), {
        aspectRatio: 1, viewMode: 1, autoCropArea: 1, responsive: true,
        background: false, zoomable: true, scalable: true, rotatable: true,
        cropBoxResizable: true, cropBoxMovable: true, dragMode: 'move',
        preview: '#cropPreview'
      });
    }

    document.getElementById('rotateLeft').addEventListener('click',  () => cropper?.rotate(-45));
    document.getElementById('rotateRight').addEventListener('click', () => cropper?.rotate(45));
    document.getElementById('flipH').addEventListener('click', () => { scaleX = -scaleX; cropper?.scaleX(scaleX); });
    document.getElementById('flipV').addEventListener('click', () => { scaleY = -scaleY; cropper?.scaleY(scaleY); });
    document.getElementById('zoomIn').addEventListener('click',    () => cropper?.zoom(0.1));
    document.getElementById('zoomOut').addEventListener('click',   () => cropper?.zoom(-0.1));
    document.getElementById('resetZoom').addEventListener('click', () => cropper?.reset());

    document.querySelectorAll('.aspect-ratio-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.aspect-ratio-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const r = parseFloat(this.dataset.ratio);
        cropper?.setAspectRatio(r === 0 ? NaN : r);
      });
    });

    document.getElementById('cropButton').addEventListener('click', () => {
      if (!cropper) return;
      const canvas = cropper.getCroppedCanvas({ width: 800, height: 800, imageSmoothingQuality: 'high' });
      canvas.toBlob(blob => {
        const img = document.getElementById('imageToCrop');
        const croppedFile = new File([blob], img.dataset.fileName, { type: 'image/jpeg', lastModified: Date.now() });
        selectedFiles[img.dataset.slotNumber] = croppedFile;
        updatePreview(img.dataset.slotNumber, URL.createObjectURL(croppedFile), true);
        bootstrap.Modal.getInstance(document.getElementById('cropModal')).hide();
        document.getElementById('imageError').textContent = '';
        document.getElementById('imageError').classList.remove('show');
        document.querySelectorAll('.image-upload-dropzone').forEach(d => d.classList.remove('has-error'));
      }, 'image/jpeg', 0.95);
    });

    document.getElementById('skipCropButton').addEventListener('click', () => {
      const img = document.getElementById('imageToCrop');
      selectedFiles[img.dataset.slotNumber] = currentFile;
      const reader = new FileReader();
      reader.onload = e => updatePreview(img.dataset.slotNumber, e.target.result, false);
      reader.readAsDataURL(currentFile);
      bootstrap.Modal.getInstance(document.getElementById('cropModal')).hide();
      document.getElementById('imageError').textContent = '';
      document.getElementById('imageError').classList.remove('show');
      document.querySelectorAll('.image-upload-dropzone').forEach(d => d.classList.remove('has-error'));
    });

    document.getElementById('cropModal').addEventListener('hidden.bs.modal', () => {
      if (cropper) { cropper.destroy(); cropper = null; }
    });

    function updatePreview(slotNumber, url, isCropped = false) {
      const slot     = document.querySelector(`.image-upload-slot[data-slot="${slotNumber}"]`);
      const dropzone = slot.querySelector('.image-upload-dropzone');
      const preview  = slot.querySelector('.image-preview');
      dropzone.classList.add('d-none');
      preview.classList.remove('d-none');
      preview.innerHTML = `
        <div class="img-wrapper">
          <img src="${url}" alt="Preview" class="img-fit">
          <span class="img-badge ${isCropped ? 'badge-success' : 'badge-info'}">
            ${isCropped ? '✓ Cropped' : 'Original'}
          </span>
          <button type="button" class="remove-image-btn" data-slot="${slotNumber}">×</button>
          <button type="button" class="recrop-image-btn" data-slot="${slotNumber}">Re-crop</button>
        </div>`;
      preview.querySelector('.remove-image-btn').addEventListener('click', () => removeImage(slotNumber));
      preview.querySelector('.recrop-image-btn').addEventListener('click', () => {
        const file = selectedFiles[slotNumber];
        if (!file) return;
        currentFile = file; currentSlotNumber = slotNumber;
        openCropModal(file, slotNumber);
      });
    }

    function removeImage(slotNumber) {
      const slot     = document.querySelector(`.image-upload-slot[data-slot="${slotNumber}"]`);
      const dropzone = slot.querySelector('.image-upload-dropzone');
      const preview  = slot.querySelector('.image-preview');
      delete selectedFiles[slotNumber];
      preview.classList.add('d-none'); preview.innerHTML = '';
      dropzone.classList.remove('d-none');
      const inp = slot.querySelector('input[type="file"]');
      if (inp) inp.value = '';
    }

    // ══════════════════════════════════════════
    // FORM SUBMISSION
    // ══════════════════════════════════════════
    document.getElementById('addProductForm').addEventListener('submit', async function (e) {
      e.preventDefault();

      // Run full validation
      if (!validateForm()) {
        // scroll to first error
        const firstErr = document.querySelector('.is-invalid, .error-message.show');
        if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Adding...';

      const formData = new FormData();
      formData.append('productName', document.getElementById('productName').value.trim());
      formData.append('description', document.getElementById('description').value.trim());
      formData.append('category',    document.getElementById('category').value);
      formData.append('regularPrice', document.getElementById('regularPrice').value);
      formData.append('salePrice',   document.getElementById('salePrice').value || '0');
      formData.append('status',      document.getElementById('status').value);
      formData.append('stock_S',     document.getElementById('stock_S').value);
      formData.append('stock_M',     document.getElementById('stock_M').value);
      formData.append('stock_L',     document.getElementById('stock_L').value);
      formData.append('stock_XL',    document.getElementById('stock_XL').value);
      formData.append('stock_XXL',   document.getElementById('stock_XXL').value);
      formData.append('size',        document.getElementById('size-array').value);

      for (const [, file] of Object.entries(selectedFiles)) {
        formData.append('images', file);
      }

      try {
        const response = await fetch('/admin/products', { method: 'POST', body: formData });
        const result   = await response.json();

        if (result.success) {
          Swal.fire({
            icon: 'success', title: 'Product Added!',
            text: 'Product has been created successfully.',
            confirmButtonColor: '#0202a1'
          }).then(() => window.location.href = '/admin/products');
        } else if (response.status === 409) {
          // duplicate name — show inline
          showError('productName', result.message || 'Product name already exists.');
          document.getElementById('productName').scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          Swal.fire({ icon: 'error', title: 'Error', text: result.message || 'Failed to add product.', confirmButtonColor: '#0202a1' });
        }
      } catch (error) {
        Swal.fire({ icon: 'error', title: 'Network Error', text: 'Could not connect to server.', confirmButtonColor: '#0202a1' });
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-plus-circle me-2"></i> Add Product';
      }
    });

  });
  </script>
</body>
</html>