<%- include("../partials/admin/header") %>

<style>
    :root {
        --sidebar-width: 250px;
        --primary-blue: #3b6da1;
        --accent-purple: #3e29a8;
        --bg-body: #f5f7fa;
    }

    .status-active {
        background-color: #e6fffa;
        color: #0CAF60;
        border: 1px solid #0CAF60;
        font-weight: 500;
    }

    .status-blocked {
        background-color: #f9d3d3;
        color: #FD6A6A;
        border: 1px solid #FD6A6A;
        font-weight: 500;
    }

    .main-content {
        padding: 30px;
        background: var(--bg-body);
        min-height: 100vh;
        margin-left: var(--sidebar-width);
    }

    .table thead th {
        background: var(--primary-blue);
        color: white;
        font-weight: 500;
        border: none;
        padding: 15px;
    }

    .search-btn {
        background-color: var(--accent-purple);
        color: white;
    }

    .product-img {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        object-fit: cover;
        background: #fff;
        border: 1px solid #eee;
    }

    .pagination .page-link {
        color: var(--primary-blue);
        border: none;
        margin: 0 3px;
        border-radius: 8px;
    }

    .pagination .page-item.active .page-link {
        background-color: var(--primary-blue);
        color: white;
    }

    @media (max-width: 992px) {
        .main-content { margin-left: 0; padding: 20px; }
    }

    .price-container {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .regular-price {
        text-decoration: line-through;
        color: #999;
        font-size: 0.82rem;
    }

    .final-price {
        color: #192430;
        font-weight: 700;
        font-size: 0.95rem;
    }
</style>

<aside class="sidebar d-none d-lg-block">
    <%- include("../partials/admin/sidebar_links") %>
</aside>

<main class="main-content">
    <div class="container-fluid">
        <div class="mb-4">
            <h2 class="fw-bold m-0" style="font-family: 'Outfit', sans-serif;">Product Management</h2>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-8">
                        <label class="small text-muted mb-1">Search Products</label>
                        <div class="input-group">
                            <input id="searchInput" type="text" class="form-control shadow-none"
                                placeholder="Search products..." value="<%= search || '' %>" />
                            <button id="searchBtn" class="btn search-btn px-4">Search</button>
                            <a href="/admin/products" class="btn btn-outline-secondary">Reset</a>
                        </div>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <a href="/admin/products/add" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm">
                            <i class="bi bi-plus-lg me-2"></i>Add Product
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Product Details</th>
                            <th>Category</th>
                            <th>Price (₹)</th>
                            <th>Stock</th>
                            <th>Sizes</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof products !== 'undefined' && products && products.length > 0) { %>
                            <% products.forEach(p => {
                                const totalStock = p.stock
                                    ? Object.values(p.stock).reduce((s, q) => s + (parseInt(q) || 0), 0)
                                    : 0;
                                const dotClass = totalStock === 0
                                    ? 'text-danger'
                                    : totalStock <= 5 ? 'text-warning' : 'text-success';

                                const regular = Number(p.regularPrice || 0);
                                const sale = Number(p.salePrice || 0);
                                const isOnSale = sale > 0 && sale < regular;
                                const finalPrice = isOnSale ? sale : regular;
                                const discountPct = isOnSale
                                    ? Math.round((regular - sale) / regular * 100)
                                    : 0;
                            %>
                            <tr>
                                <!-- Product Details -->
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <img class="product-img"
                                            src="<%= (p.productImage && p.productImage[0]) ? p.productImage[0] : 'https://via.placeholder.com/44' %>"
                                            alt="<%= p.productName %>" />
                                        <div>
                                            <div class="fw-bold text-dark"><%= p.productName %></div>
                                            <small class="text-muted">ID: <%= p._id.toString().substring(0,8) %>...</small>
                                        </div>
                                    </div>
                                </td>

                                <!-- Category -->
                                <td>
                                    <span class="badge bg-light text-dark border fw-normal">
                                        <%= p.category ? p.category.name : 'Uncategorized' %>
                                    </span>
                                </td>

                                <!-- Price -->
                                <td>
                                    <div class="price-container">
                                        <% if (isOnSale) { %>
                                            <span class="final-price">₹<%= finalPrice.toFixed(2) %></span>
                                            <span class="regular-price">₹<%= regular.toFixed(2) %></span>
                                        <% } else { %>
                                            <span class="final-price">₹<%= regular.toFixed(2) %></span>
                                        <% } %>
                                    </div>
                                </td>

                                <!-- Stock -->
                                <td>
                                    <div class="fw-bold <%= dotClass %>"><%= totalStock %> units</div>
                                </td>

                                <!-- Sizes -->
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        <% if (Array.isArray(p.size) && p.size.length > 0) { %>
                                            <% p.size.forEach(s => { %>
                                                <span class="badge bg-light text-dark border" style="font-size:0.72rem;">
                                                    <%= s %>
                                                </span>
                                            <% }) %>
                                        <% } else { %>
                                            <span class="text-muted">—</span>
                                        <% } %>
                                    </div>
                                </td>

                                <!-- Status -->
                                <td>
                                    <span class="badge rounded-pill px-3 py-2 <%= p.isBlocked ? 'status-blocked' : 'status-active' %>">
                                        <%= p.isBlocked ? 'Blocked' : (p.status || 'Active') %>
                                    </span>
                                </td>

                                <!-- Actions -->
                                <td class="text-end pe-4">
                                    <div class="btn-group border rounded-3 bg-white shadow-sm overflow-hidden">
                                        <a href="/admin/products/edit/<%= p._id %>"
                                            class="btn btn-sm btn-white py-2 px-3 border-end"
                                            title="Edit">
                                            <i class="bi bi-pencil-square text-primary"></i>
                                        </a>
                                        <button class="btn btn-sm btn-white py-2 px-3 toggle-block"
                                            data-id="<%= p._id %>"
                                            data-blocked="<%= !!p.isBlocked %>"
                                            title="<%= p.isBlocked ? 'Unblock' : 'Block' %>">
                                            <i class="bi <%= p.isBlocked ? 'bi-toggle-on text-danger' : 'bi-toggle-off text-muted' %> fs-5"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No products found.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- ✅ Pagination - matches customers page style (hidden when only 1 page) -->
            <% if (typeof totalPages !== 'undefined' && totalPages >= 1) { %>
                <div class="d-flex justify-content-center py-3">
                    <nav>
                        <ul class="pagination mb-0">

                            <!-- Previous -->
                            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                <a class="page-link" href="?page=<%= currentPage - 1 %>&search=<%= search || '' %>">←</a>
                            </li>

                            <!-- Page numbers with ellipsis -->
                            <% for (let i = 1; i <= totalPages; i++) { %>
                                <% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %>&search=<%= search || '' %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                                    <li class="page-item disabled"><span class="page-link">…</span></li>
                                <% } %>
                            <% } %>

                            <!-- Next -->
                            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                <a class="page-link" href="?page=<%= currentPage + 1 %>&search=<%= search || '' %>">→</a>
                            </li>

                        </ul>
                    </nav>
                </div>
            <% } %>
        </div>
    </div>
</main>

<%- include("../partials/admin/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener('DOMContentLoaded', function () {

    // Search
    const handleSearch = () => {
        const val = document.getElementById('searchInput').value.trim();
        window.location.href = val
            ? `/admin/products?search=${encodeURIComponent(val)}`
            : '/admin/products';
    };
    document.getElementById('searchBtn')?.addEventListener('click', handleSearch);
    document.getElementById('searchInput')?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') handleSearch();
    });

    // Block / Unblock toggle
    document.querySelectorAll('.toggle-block').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id = btn.dataset.id;
            const isBlocked = btn.dataset.blocked === 'true';

            const result = await Swal.fire({
                title: isBlocked ? 'Unblock Product?' : 'Block Product?',
                text: isBlocked
                    ? 'This product will be visible to customers again.'
                    : 'Customers will not be able to see this product.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes',
                cancelButtonText: 'No'
            });

            if (result.isConfirmed) {
                try {
                    const res = await fetch(`/admin/products/${id}/block`, { method: 'PUT' });
                    const data = await res.json();
                    if (data.success) {
                        location.reload();
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (err) {
                    Swal.fire('Error', 'Something went wrong', 'error');
                }
            }
        });
    });

});
</script>