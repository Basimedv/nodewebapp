<%- include("../partials/admin/header") %>

<style>
    .status-active  { background-color:#8af5bf; color:#0CAF60; border:1px solid #0CAF60; font-weight:500; }
    .status-blocked { background-color:#f9d3d3; color:#FD6A6A; border:1px solid #FD6A6A; font-weight:500; }

    .main-content {
        padding: 30px;
        background: #f5f7fa;
        min-height: 100vh;
        margin-left: 250px;
    }

    .table thead th {
        background: #3b6da1;
        color: white;
        font-weight: 500;
        border: none;
        padding: 15px;
    }

    .search-btn       { background-color:#3e29a8; color:white; }
    .search-btn:hover { background-color:#2e1e82; color:white; }

    .search-wrapper              { position: relative; flex: 1; }
    .search-wrapper .form-control { padding-right: 2.2rem; }
    #clearSearch {
        position: absolute; right:.55rem; top:50%;
        transform: translateY(-50%);
        background: none; border: none;
        font-size: .95rem; color: #aaa;
        cursor: pointer; display: none; z-index: 5;
    }
    #clearSearch:hover { color:#555; }

    .pagination .page-link { color:#3b6da1; border:none; margin:0 3px; border-radius:8px; }
    .pagination .page-item.active .page-link { background-color:#3b6da1; color:white; }

    /* Validation styles */
    .input-error {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220,53,69,.15) !important;
    }
    .field-error {
        color: #dc3545;
        font-size: 0.8rem;
        margin-top: 4px;
        display: none;
    }
    .field-error.show { display: block; }

    /* Character counter */
    .char-count {
        font-size: 0.75rem;
        color: #aaa;
        text-align: right;
        margin-top: 3px;
    }
    .char-count.warn { color: #e67e22; }
    .char-count.over { color: #dc3545; }

    @media(max-width:992px){ .main-content{ margin-left:0; padding:20px; } }
</style>

<aside class="sidebar d-none d-lg-block">
    <%- include("../partials/admin/sidebar_links") %>
</aside>

<main class="main-content">
<div class="container-fluid">

    <div class="mb-4">
        <h2 class="fw-bold m-0" style="font-family:'Outfit',sans-serif;">Category Management</h2>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label class="small text-muted mb-1">Search Categories</label>
                    <div class="input-group">
                        <div class="search-wrapper">
                            <input id="searchInput" type="text"
                                   class="form-control shadow-none"
                                   placeholder="Search by name…"
                                   value="<%= searchQuery || '' %>" />
                            <button id="clearSearch" type="button" title="Clear">✕</button>
                        </div>
                        <button id="searchBtn" class="btn search-btn px-4">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                    </div>
                </div>
                <div class="col-md-4 text-md-end">
                    <button class="btn btn-primary px-4 py-2 rounded-3 shadow-sm"
                            data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                        <i class="bi bi-plus-lg me-2"></i>Add Category
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">#</th>
                        <th>Category Name</th>
                        <th>Items</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (cat && cat.length > 0) { %>
                        <% cat.forEach((category, i) => { %>
                        <tr>
                            <td class="ps-4 text-muted small">
                                <%= (currentPage - 1) * 10 + i + 1 %>
                            </td>
                            <td class="fw-bold text-dark"><%= category.name %></td>
                            <td class="text-muted small"><%= category.itemsCount %></td>
                            <td>
                                <span class="badge rounded-pill px-3 py-2
                                    <%= category.isListed === false ? 'status-blocked' : 'status-active' %>">
                                    <%= category.isListed === false ? 'Blocked' : 'Active' %>
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group border rounded-3 bg-white shadow-sm overflow-hidden">
                                    <button class="btn btn-sm btn-white py-2 px-3 border-end btn-edit-category"
                                            title="Edit"
                                            data-name="<%= category.name %>"
                                            data-status="<%= category.isListed ? 'active' : 'inactive' %>">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                    </button>
                                    <button class="btn btn-sm btn-white py-2 px-3 toggle-block"
                                            title="<%= category.isListed ? 'Block' : 'Unblock' %>"
                                            data-name="<%= category.name %>"
                                            data-blocked="<%= category.isListed === false %>">
                                        <i class="bi <%= category.isListed === false
                                            ? 'bi-toggle-on text-danger'
                                            : 'bi-toggle-off text-muted' %> fs-5"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">No categories found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (totalPages >= 1) { %>
        <div class="d-flex justify-content-center py-3">
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                        <a class="page-link"
                           href="?page=<%= currentPage - 1 %>&query=<%= encodeURIComponent(searchQuery || '') %>">←</a>
                    </li>
                    <%
                        for (let i = 1; i <= totalPages; i++) {
                            if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                    %>
                        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                            <a class="page-link"
                               href="?page=<%= i %>&query=<%= encodeURIComponent(searchQuery || '') %>">
                                <%= i %>
                            </a>
                        </li>
                    <%
                            } else if (i === currentPage - 3 || i === currentPage + 3) {
                    %>
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    <%
                            }
                        }
                    %>
                    <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                        <a class="page-link"
                           href="?page=<%= currentPage + 1 %>&query=<%= encodeURIComponent(searchQuery || '') %>">→</a>
                    </li>
                </ul>
            </nav>
        </div>
        <% } %>
    </div>
</div>
</main>

<!-- ADD CATEGORY MODAL -->
<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="fw-bold">Add Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <div class="mb-4">
                    <label class="form-label small fw-semibold">
                        Name <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="addCatName"
                           class="form-control shadow-none rounded-3"
                           placeholder="e.g. Men's Wear"
                           maxlength="50" />
                    <div class="char-count" id="addCatNameCount">0 / 50</div>
                    <div class="field-error" id="addCatNameError"></div>
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-semibold">Status</label>
                    <select id="addCatStatus" class="form-select shadow-none rounded-3">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                <button id="addCatSubmit" class="btn btn-primary w-100 py-2 rounded-3">
                    Add Category
                </button>
            </div>
        </div>
    </div>
</div>

<!-- EDIT CATEGORY MODAL -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="fw-bold">Edit Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 pb-4">
                <input type="hidden" id="editCatOrgName" />
                <div class="mb-4">
                    <label class="form-label small fw-semibold">
                        Name <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="editCatName"
                           class="form-control shadow-none rounded-3"
                           maxlength="50" />
                    <div class="char-count" id="editCatNameCount">0 / 50</div>
                    <div class="field-error" id="editCatNameError"></div>
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-semibold">Status</label>
                    <select id="editCatStatus" class="form-select shadow-none rounded-3">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                <button id="editCatSubmit" class="btn btn-primary w-100 py-2 rounded-3">
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

<%- include("../partials/admin/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {

    // ── helpers ──────────────────────────────────────────────────
    function showErr(id, msg) {
        const el = document.getElementById(id);
        el.textContent = msg;
        el.classList.add('show');
    }
    function clearErr(id) {
        const el = document.getElementById(id);
        el.textContent = '';
        el.classList.remove('show');
    }
    function markInvalid(inputId) {
        document.getElementById(inputId).classList.add('input-error');
    }
    function markValid(inputId) {
        document.getElementById(inputId).classList.remove('input-error');
    }
    function updateCharCount(inputId, countId, max) {
        const len = document.getElementById(inputId).value.length;
        const el  = document.getElementById(countId);
        el.textContent = `${len} / ${max}`;
        el.className = 'char-count' + (len >= max ? ' over' : len >= max * 0.8 ? ' warn' : '');
    }

    // validate category name — returns error string or ''
    function validateName(value, fieldLabel = 'Name') {
        if (!value.trim()) return `${fieldLabel} is required.`;
        if (value.trim().length < 2) return `${fieldLabel} must be at least 2 characters.`;
        if (value.trim().length > 50) return `${fieldLabel} must not exceed 50 characters.`;
        if (!/^[a-zA-Z0-9\s'&\-]+$/.test(value.trim()))
            return `${fieldLabel} can only contain letters, numbers, spaces, apostrophes, & and -.`;
        return '';
    }

    // ── Search ───────────────────────────────────────────────────
    const searchInput = document.getElementById('searchInput');
    const clearBtn    = document.getElementById('clearSearch');

    const syncClear = () => {
        clearBtn.style.display = searchInput.value.trim() ? 'block' : 'none';
    };
    syncClear();
    searchInput.addEventListener('input', syncClear);

    clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        window.location.href = '/admin/categories?page=1';
    });

    const doSearch = () => {
        const val = searchInput.value.trim();
        window.location.href = `/admin/categories?query=${encodeURIComponent(val)}&page=1`;
    };
    document.getElementById('searchBtn').addEventListener('click', doSearch);
    searchInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') doSearch(); });

    // ── ADD CATEGORY ─────────────────────────────────────────────
    const addModal = new bootstrap.Modal(document.getElementById('addCategoryModal'));

    // reset on open
    document.getElementById('addCategoryModal').addEventListener('show.bs.modal', () => {
        document.getElementById('addCatName').value   = '';
        document.getElementById('addCatStatus').value = 'active';
        clearErr('addCatNameError');
        markValid('addCatName');
        updateCharCount('addCatName', 'addCatNameCount', 50);
    });

    // live validation + char count
    document.getElementById('addCatName').addEventListener('input', () => {
        updateCharCount('addCatName', 'addCatNameCount', 50);
        const err = validateName(document.getElementById('addCatName').value);
        if (err) { showErr('addCatNameError', err); markInvalid('addCatName'); }
        else      { clearErr('addCatNameError');     markValid('addCatName');   }
    });

    document.getElementById('addCatSubmit').addEventListener('click', async () => {
        const name   = document.getElementById('addCatName').value.trim();
        const status = document.getElementById('addCatStatus').value;

        // client-side validation
        const err = validateName(name);
        if (err) {
            showErr('addCatNameError', err);
            markInvalid('addCatName');
            document.getElementById('addCatName').focus();
            return;
        }
        clearErr('addCatNameError');
        markValid('addCatName');

        const btn = document.getElementById('addCatSubmit');
        btn.disabled    = true;
        btn.textContent = 'Adding…';

        try {
            const res  = await fetch('/admin/addCategory', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ name, status }),
            });
            const data = await res.json();

            if (res.ok) {
                addModal.hide();
                Swal.fire({
                    icon: 'success', title: 'Category Added',
                    showConfirmButton: false, timer: 1300
                }).then(() => location.reload());
            } else if (res.status === 409) {
                // duplicate name — show inline
                showErr('addCatNameError', data.error || 'Category already exists.');
                markInvalid('addCatName');
                document.getElementById('addCatName').focus();
            } else {
                Swal.fire({ icon: 'error', title: 'Error', text: data.error || 'Something went wrong.' });
            }
        } catch {
            Swal.fire({ icon: 'error', title: 'Network Error', text: 'Request failed.' });
        } finally {
            btn.disabled    = false;
            btn.textContent = 'Add Category';
        }
    });

    // ── EDIT CATEGORY ────────────────────────────────────────────
    const editModal = new bootstrap.Modal(document.getElementById('editCategoryModal'));

    document.querySelectorAll('.btn-edit-category').forEach((btn) => {
        btn.addEventListener('click', () => {
            document.getElementById('editCatOrgName').value = btn.dataset.name;
            document.getElementById('editCatName').value    = btn.dataset.name;
            document.getElementById('editCatStatus').value  = btn.dataset.status;
            clearErr('editCatNameError');
            markValid('editCatName');
            updateCharCount('editCatName', 'editCatNameCount', 50);
            editModal.show();
        });
    });

    // live validation + char count
    document.getElementById('editCatName').addEventListener('input', () => {
        updateCharCount('editCatName', 'editCatNameCount', 50);
        const err = validateName(document.getElementById('editCatName').value);
        if (err) { showErr('editCatNameError', err); markInvalid('editCatName'); }
        else      { clearErr('editCatNameError');     markValid('editCatName');  }
    });

    document.getElementById('editCatSubmit').addEventListener('click', async () => {
        const orgName    = document.getElementById('editCatOrgName').value;
        const editName   = document.getElementById('editCatName').value.trim();
        const editStatus = document.getElementById('editCatStatus').value;

        // client-side validation
        const err = validateName(editName);
        if (err) {
            showErr('editCatNameError', err);
            markInvalid('editCatName');
            document.getElementById('editCatName').focus();
            return;
        }
        clearErr('editCatNameError');
        markValid('editCatName');

        const btn = document.getElementById('editCatSubmit');
        btn.disabled    = true;
        btn.textContent = 'Saving…';

        try {
            const res  = await fetch('/admin/categories', {
                method:  'PUT',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ orgName, editName, editStatus }),
            });
            const data = await res.json();

            if (res.ok) {
                editModal.hide();
                Swal.fire({
                    icon: 'success', title: 'Category Updated',
                    showConfirmButton: false, timer: 1300
                }).then(() => location.reload());
            } else if (res.status === 409) {
                showErr('editCatNameError', data.nameError || 'Name already exists.');
                markInvalid('editCatName');
                document.getElementById('editCatName').focus();
            } else {
                Swal.fire({ icon: 'error', title: 'Error', text: data.error || 'Something went wrong.' });
            }
        } catch {
            Swal.fire({ icon: 'error', title: 'Network Error', text: 'Request failed.' });
        } finally {
            btn.disabled    = false;
            btn.textContent = 'Save Changes';
        }
    });

    // ── BLOCK / UNBLOCK ──────────────────────────────────────────
    document.querySelectorAll('.toggle-block').forEach((btn) => {
        btn.addEventListener('click', async () => {
            const name      = btn.dataset.name;
            const isBlocked = btn.dataset.blocked === 'true';

            const result = await Swal.fire({
                title: isBlocked ? 'Unblock Category?' : 'Block Category?',
                text:  `"${name}" will be set to ${isBlocked ? 'Active' : 'Blocked'}.`,
                icon:  'warning',
                showCancelButton:   true,
                confirmButtonColor: isBlocked ? '#28a745' : '#dc3545',
                confirmButtonText:  'Yes, proceed',
                cancelButtonText:   'Cancel'
            });
            if (!result.isConfirmed) return;

            try {
                const res = await fetch('/admin/categories', {
                    method:  'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({
                        orgName:    name,
                        editName:   name,
                        editStatus: isBlocked ? 'active' : 'inactive'
                    }),
                });
                const data = await res.json();

                if (res.ok) {
                    Swal.fire({
                        icon: 'success', title: 'Status Updated',
                        showConfirmButton: false, timer: 1000
                    }).then(() => location.reload());
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: data.error || 'Failed.' });
                }
            } catch {
                Swal.fire({ icon: 'error', title: 'Network Error', text: 'Request failed.' });
            }
        });
    });

});
</script>