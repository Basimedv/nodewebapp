<%- include("../partials/admin/header") %>  
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; color: #1a1a2e; }

    .main-content { margin-left: 240px; padding: 0 0 60px; }

    .page-header {
      background: #fff;
      border-bottom: 1px solid #e4e6eb;
      padding: 18px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky; top: 0; z-index: 100;
    }
    .back-link { display: flex; align-items: center; gap: 8px; color: #5b5ef4; text-decoration: none; font-size: 13.5px; font-weight: 500; transition: gap 0.2s; }
    .back-link:hover { gap: 12px; color: #4a4dd6; }
    .header-right { display: flex; align-items: center; gap: 12px; }

    .status-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; padding: 5px 14px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.4px; }
    .status-badge::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: currentColor; opacity: 0.7; }
    .s-Pending        { background: #fef9ee; color: #d97706; }
    .s-Processing     { background: #eff6ff; color: #2563eb; }
    .s-Shipped        { background: #ecfeff; color: #0891b2; }
    .s-OutForDelivery { background: #f0fdf4; color: #059669; }
    .s-Delivered      { background: #dcfce7; color: #16a34a; }
    .s-Cancelled      { background: #fef2f2; color: #dc2626; }
    .s-ReturnRequest  { background: #fdf4ff; color: #9333ea; }
    .s-Returned       { background: #faf5ff; color: #7c3aed; }

    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 20px;
      padding: 24px 32px;
    }
    .left-col { display: flex; flex-direction: column; gap: 20px; }
    .right-col { display: flex; flex-direction: column; gap: 20px; }

    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.07);
      overflow: hidden;
    }
    .card-head {
      padding: 16px 20px;
      border-bottom: 1px solid #f0f0f0;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .card-head h3 { font-size: 14px; font-weight: 700; color: #1a1a2e; display: flex; align-items: center; gap: 8px; margin: 0; }
    .card-head h3 i { color: #5b5ef4; font-size: 13px; }
    .card-body { padding: 20px; }

    .meta-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .meta-item .meta-label { font-size: 11px; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .meta-item .meta-value { font-size: 14px; font-weight: 600; color: #1a1a2e; }
    .meta-item .meta-value.id { font-family: 'Courier New', monospace; color: #5b5ef4; }
    .pay-badge { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
    .pay-cod    { background: #fef3e2; color: #d97706; }
    .pay-online { background: #e0f2fe; color: #0284c7; }
    .pay-wallet { background: #f0fdf4; color: #16a34a; }

    .timeline { display: flex; align-items: flex-start; gap: 0; padding: 8px 0; overflow-x: auto; }
    .timeline-step { flex: 1; display: flex; flex-direction: column; align-items: center; position: relative; min-width: 80px; }
    .timeline-step:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 16px;
      left: calc(50% + 16px);
      right: calc(-50% + 16px);
      height: 2px;
      background: #e4e6eb;
      z-index: 0;
    }
    .timeline-step.done:not(:last-child)::after { background: #5b5ef4; }
    .step-dot {
      width: 32px; height: 32px; border-radius: 50%;
      background: #f0f0f0; border: 2px solid #e4e6eb;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; color: #bbb; position: relative; z-index: 1;
      transition: all 0.2s;
    }
    .timeline-step.done .step-dot { background: #5b5ef4; border-color: #5b5ef4; color: #fff; }
    .timeline-step.current .step-dot { background: #fff; border-color: #5b5ef4; color: #5b5ef4; box-shadow: 0 0 0 4px rgba(91,94,244,0.15); }
    .step-label { font-size: 10.5px; font-weight: 600; color: #aaa; margin-top: 7px; text-align: center; line-height: 1.3; }
    .timeline-step.done .step-label,
    .timeline-step.current .step-label { color: #5b5ef4; }

    .items-table { width: 100%; border-collapse: collapse; }
    .items-table th { font-size: 11px; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.5px; padding: 10px 12px; border-bottom: 2px solid #f5f5f5; text-align: left; }
    .items-table td { padding: 14px 12px; border-bottom: 1px solid #f8f8f8; vertical-align: middle; font-size: 13.5px; }
    .items-table tr:last-child td { border-bottom: none; }
    .product-cell { display: flex; align-items: center; gap: 12px; }
    .product-thumb { width: 52px; height: 52px; border-radius: 8px; object-fit: cover; border: 1px solid #eee; flex-shrink: 0; }
    .product-thumb-placeholder { width: 52px; height: 52px; border-radius: 8px; background: #f5f5f5; border: 1px solid #eee; display: flex; align-items: center; justify-content: center; color: #ccc; flex-shrink: 0; }
    .product-name { font-weight: 600; color: #1a1a2e; font-size: 13.5px; }
    .product-meta { font-size: 11.5px; color: #999; margin-top: 2px; }
    .size-chip { display: inline-block; background: #f4f5ff; color: #5b5ef4; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 4px; }

    .price-row { display: flex; justify-content: space-between; align-items: center; padding: 9px 0; font-size: 13.5px; border-bottom: 1px solid #f5f5f5; }
    .price-row:last-child { border-bottom: none; }
    .price-row .label { color: #666; }
    .price-row .value { font-weight: 600; color: #1a1a2e; }
    .price-row.total { padding-top: 14px; margin-top: 4px; border-top: 2px solid #f0f0f0; border-bottom: none; }
    .price-row.total .label { font-size: 15px; font-weight: 700; color: #1a1a2e; }
    .price-row.total .value { font-size: 17px; font-weight: 800; color: #5b5ef4; }
    .discount-value { color: #16a34a !important; }

    .address-box { font-size: 13.5px; line-height: 1.7; color: #444; }
    .address-box strong { color: #1a1a2e; font-size: 14px; display: block; margin-bottom: 2px; }

    .customer-info { display: flex; flex-direction: column; gap: 10px; }
    .info-row { display: flex; align-items: flex-start; gap: 10px; font-size: 13.5px; }
    .info-row i { color: #5b5ef4; font-size: 13px; margin-top: 2px; flex-shrink: 0; }
    .info-row span { color: #444; }

    .status-form { display: flex; flex-direction: column; gap: 12px; }
    .status-select {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid #e4e6eb;
      border-radius: 8px;
      font-size: 13.5px;
      outline: none;
      background: #fff;
      transition: border-color 0.2s;
    }
    .status-select:focus { border-color: #5b5ef4; box-shadow: 0 0 0 3px rgba(91,94,244,0.1); }
    .btn-update { background: #5b5ef4; color: #fff; border: none; padding: 11px; border-radius: 8px; font-size: 13.5px; font-weight: 600; cursor: pointer; transition: background 0.2s; width: 100%; }
    .btn-update:hover { background: #4a4dd6; }
    .btn-update:disabled { opacity: 0.5; cursor: not-allowed; }

    .return-box { background: #fdf4ff; border: 1px solid #e9d5ff; border-radius: 8px; padding: 14px; }
    .return-box .return-label { font-size: 11px; font-weight: 700; color: #9333ea; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
    .return-box .return-reason { font-size: 13px; color: #555; margin-bottom: 12px; line-height: 1.5; }
    .return-actions { display: flex; gap: 8px; }
    .btn-approve { flex: 1; background: #16a34a; color: #fff; border: none; padding: 9px; border-radius: 7px; font-size: 13px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    .btn-approve:hover { background: #15803d; }
    .btn-reject  { flex: 1; background: #fff; color: #dc2626; border: 1px solid #fca5a5; padding: 9px; border-radius: 7px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn-reject:hover { background: #fef2f2; }

    .cancelled-note { background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; font-size: 13px; color: #dc2626; display: flex; align-items: flex-start; gap: 8px; }
    .delivered-note { background: #dcfce7; border: 1px solid #bbf7d0; border-radius: 8px; padding: 12px 16px; font-size: 13px; color: #16a34a; display: flex; align-items: flex-start; gap: 8px; }

    @media (max-width: 1024px) {
      .detail-grid { grid-template-columns: 1fr; }
      .right-col { flex-direction: row; flex-wrap: wrap; }
      .right-col .card { flex: 1; min-width: 280px; }
    }
    @media (max-width: 768px) {
      .main-content { margin-left: 0; }
      .detail-grid { padding: 16px; }
      .meta-grid { grid-template-columns: repeat(2, 1fr); }
      .page-header { padding: 14px 16px; flex-direction: column; gap: 10px; align-items: flex-start; }
    }
  </style>

  <aside class="sidebar d-none d-lg-block">
    <%- include("../partials/admin/sidebar_links") %>
  </aside>

  <div class="main-content">
    <%
      const statusClass = order.status.replace(/\s+/g, '');
      const payMethod   = order.paymentMethod || 'COD';
      const payClass    = payMethod === 'COD' ? 'pay-cod' : payMethod === 'Wallet' ? 'pay-wallet' : 'pay-online';
      const orderId     = order.orderId || order._id.toString().slice(-8).toUpperCase();

      const timelineSteps = [
        { key: 'Pending',           label: 'Pending',         icon: 'fa-clock' },
        { key: 'Processing',        label: 'Processing',      icon: 'fa-cog' },
        { key: 'Shipped',           label: 'Shipped',         icon: 'fa-truck' },
        { key: 'Out for Delivery',  label: 'Out for Delivery',icon: 'fa-map-marker-alt' },
        { key: 'Delivered',         label: 'Delivered',       icon: 'fa-check' }
      ];
      const statusOrder = timelineSteps.map(s => s.key);
      const currentIdx  = statusOrder.indexOf(order.status);
    %>

    <!-- PAGE HEADER -->
    <div class="page-header">
      <a href="/admin/orders" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to Orders
      </a>
      <div class="header-right">
        <span style="font-size:13px; color:#888;">Order <strong style="color:#1a1a2e;">#<%= orderId %></strong></span>
        <span class="status-badge s-<%= statusClass %>"><%= order.status %></span>
      </div>
    </div>

    <div class="detail-grid">

      <!-- LEFT COLUMN -->
      <div class="left-col">

        <!-- Order Meta -->
        <div class="card">
          <div class="card-head">
            <h3><i class="fas fa-info-circle"></i> Order Info</h3>
            <span style="font-size:12px; color:#aaa;">
              <%= new Date(order.createdOn || order.createdAt).toLocaleDateString('en-IN', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
            </span>
          </div>
          <div class="card-body">
            <div class="meta-grid">
              <div class="meta-item">
                <div class="meta-label">Order ID</div>
                <div class="meta-value id">#<%= orderId %></div>
              </div>
              <div class="meta-item">
                <div class="meta-label">Payment</div>
                <div class="meta-value"><span class="pay-badge <%= payClass %>"><%= payMethod %></span></div>
              </div>
              <div class="meta-item">
                <div class="meta-label">Payment Status</div>
                <div class="meta-value" style="color:<%= order.paymentStatus === 'Paid' ? '#16a34a' : '#d97706' %>">
                  <%= order.paymentStatus || 'Pending' %>
                </div>
              </div>
              <% if (order.couponCode) { %>
              <div class="meta-item">
                <div class="meta-label">Coupon</div>
                <div class="meta-value" style="color:#9333ea;"><%= order.couponCode %></div>
              </div>
              <% } %>
              <% if (order.invoiceDate) { %>
              <div class="meta-item">
                <div class="meta-label">Delivered On</div>
                <div class="meta-value"><%= new Date(order.invoiceDate).toLocaleDateString('en-IN') %></div>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Timeline -->
        <% if (!['Cancelled','Return Request','Returned'].includes(order.status)) { %>
        <div class="card">
          <div class="card-head"><h3><i class="fas fa-route"></i> Order Progress</h3></div>
          <div class="card-body">
            <div class="timeline">
              <% timelineSteps.forEach((step, i) => {
                let cls = '';
                if (currentIdx > i) cls = 'done';
                else if (currentIdx === i) cls = 'current';
              %>
              <div class="timeline-step <%= cls %>">
                <div class="step-dot"><i class="fas <%= step.icon %>"></i></div>
                <span class="step-label"><%= step.label %></span>
              </div>
              <% }) %>
            </div>
          </div>
        </div>
        <% } %>

        <% if (order.status === 'Cancelled') { %>
        <div class="cancelled-note">
          <i class="fas fa-times-circle"></i>
          <span>This order was cancelled. Stock has been restored.</span>
        </div>
        <% } %>

        <% if (order.status === 'Returned') { %>
        <div class="delivered-note">
          <i class="fas fa-undo"></i>
          <span>This order was returned and stock has been restored.</span>
        </div>
        <% } %>

        <!-- Ordered Items -->
        <div class="card">
          <div class="card-head">
            <h3><i class="fas fa-box-open"></i> Ordered Items</h3>
            <span style="font-size:12px; color:#aaa;"><%= order.orderedItems ? order.orderedItems.length : 0 %> item(s)</span>
          </div>
          <div class="card-body" style="padding:0;">
            <table class="items-table">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Size</th>
                  <th>Qty</th>
                  <th>Unit Price</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <% if (order.orderedItems && order.orderedItems.length > 0) { %>
                  <% order.orderedItems.forEach(item => {
                    const prod      = item.product || {};
                    const imgSrc    = (prod.productImage && prod.productImage[0]) ? prod.productImage[0] : null;
                    const itemTotal = (item.price || 0) * (item.quantity || 1);
                  %>
                  <tr>
                    <td>
                      <div class="product-cell">
                        <% if (imgSrc) { %>
                          <img src="<%= imgSrc %>" class="product-thumb" alt="">
                        <% } else { %>
                          <div class="product-thumb-placeholder"><i class="fas fa-image"></i></div>
                        <% } %>
                        <div>
                          <div class="product-name"><%= prod.productName || '—' %></div>
                          <div class="product-meta"><%= prod.category ? (prod.category.name || '') : '' %></div>
                        </div>
                      </div>
                    </td>
                    <td><span class="size-chip"><%= item.size || '—' %></span></td>
                    <td style="font-weight:600;">× <%= item.quantity || 1 %></td>
                    <td style="color:#555;">₹<%= (item.price || 0).toLocaleString('en-IN') %></td>
                    <td style="font-weight:700;">₹<%= itemTotal.toLocaleString('en-IN') %></td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="5" style="text-align:center; color:#ccc; padding:24px;">No items</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Price Summary -->
        <div class="card">
          <div class="card-head"><h3><i class="fas fa-receipt"></i> Price Summary</h3></div>
          <div class="card-body">
            <div class="price-row">
              <span class="label">Subtotal</span>
              <span class="value">₹<%= (order.totalPrice || 0).toLocaleString('en-IN') %></span>
            </div>
            <% if (order.discount && order.discount > 0) { %>
            <div class="price-row">
              <span class="label">Discount</span>
              <span class="value discount-value">− ₹<%= order.discount.toLocaleString('en-IN') %></span>
            </div>
            <% } %>
            <% if (order.couponDiscount && order.couponDiscount > 0) { %>
            <div class="price-row">
              <span class="label">Coupon (<%= order.couponCode || '' %>)</span>
              <span class="value discount-value">− ₹<%= order.couponDiscount.toLocaleString('en-IN') %></span>
            </div>
            <% } %>
            <div class="price-row">
              <span class="label">Shipping</span>
              <span class="value"><%= (order.shippingCharge || 0) === 0 ? 'Free' : '₹' + (order.shippingCharge || 0).toLocaleString('en-IN') %></span>
            </div>
            <div class="price-row total">
              <span class="label">Total Paid</span>
              <span class="value">₹<%= (order.finalAmount || order.totalPrice || 0).toLocaleString('en-IN') %></span>
            </div>
          </div>
        </div>

      </div><!-- /left-col -->

      <!-- RIGHT COLUMN -->
      <div class="right-col">

        <!-- Update Status -->
        <div class="card">
          <div class="card-head"><h3><i class="fas fa-edit"></i> Update Status</h3></div>
          <div class="card-body">
            <% if (order.status === 'Cancelled') { %>
              <div class="cancelled-note" style="margin:0;">
                <i class="fas fa-lock"></i>
                <span>Cancelled orders cannot be updated.</span>
              </div>
            <% } else if (order.status === 'Return Request') { %>
              <div style="color:#9333ea; font-size:13px; background:#fdf4ff; padding:10px 14px; border-radius:8px; border:1px solid #e9d5ff;">
                <i class="fas fa-undo me-1"></i> A return request is pending review below.
              </div>
            <% } else { %>
              <div class="status-form">
                <select class="status-select" id="statusSelect">
                  <% ['Pending','Processing','Shipped','Out for Delivery','Delivered','Cancelled'].forEach(s => { %>
                    <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
                  <% }) %>
                </select>
                <button class="btn-update" id="updateStatusBtn" onclick="updateStatus()">
                  <i class="fas fa-save me-1"></i> Save Status
                </button>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Return Request -->
        <% if (order.status === 'Return Request') { %>
        <div class="card">
          <div class="card-head"><h3><i class="fas fa-undo"></i> Return Request</h3></div>
          <div class="card-body">
            <div class="return-box">
              <div class="return-label"><i class="fas fa-exclamation-circle"></i> Return Requested</div>
              <div class="return-reason">
                <strong style="color:#9333ea; font-size:11px; text-transform:uppercase; letter-spacing:0.4px;">Customer's Reason:</strong>
                <p style="margin:6px 0 0; font-size:13.5px; color:#333; line-height:1.6; background:#fff; border-left:3px solid #9333ea; padding:8px 12px; border-radius:0 6px 6px 0;">
                  <% if (order.returnReason && order.returnReason.trim().length > 0) { %>
                    <%= order.returnReason %>
                  <% } else { %>
                    <span style="color:#aaa; font-style:italic;">No reason provided by customer.</span>
                  <% } %>
                </p>
              </div>
              <div class="return-actions" style="margin-top:14px;">
                <button class="btn-approve" onclick="handleReturn('approve')">
                  <i class="fas fa-check me-1"></i> Approve
                </button>
                <button class="btn-reject" onclick="handleReturn('reject')">
                  <i class="fas fa-times me-1"></i> Reject
                </button>
              </div>
            </div>
          </div>
        </div>
        <% } %>

        <!-- Customer Info -->
        <div class="card">
          <div class="card-head"><h3><i class="fas fa-user"></i> Customer</h3></div>
          <div class="card-body">
            <div class="customer-info">
              <div class="info-row">
                <i class="fas fa-user-circle"></i>
                <span><strong><%= order.userId ? order.userId.fullName : '—' %></strong></span>
              </div>
              <% if (order.userId && order.userId.email) { %>
              <div class="info-row">
                <i class="fas fa-envelope"></i>
                <span><%= order.userId.email %></span>
              </div>
              <% } %>
              <% if (order.userId && order.userId.phone) { %>
              <div class="info-row">
                <i class="fas fa-phone"></i>
                <span><%= order.userId.phone %></span>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Delivery Address -->
        <% if (order.address) { %>
        <div class="card">
          <div class="card-head"><h3><i class="fas fa-map-marker-alt"></i> Delivery Address</h3></div>
          <div class="card-body">
            <div class="address-box">
              <strong><%= order.userId ? order.userId.fullName : '' %></strong>
              <%= order.address %>
            </div>
          </div>
        </div>
        <% } %>

      </div><!-- /right-col -->
    </div><!-- /detail-grid -->
  </div><!-- /main-content -->

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    const ORDER_ID = '<%= order._id %>';

    async function updateStatus() {
      const select = document.getElementById('statusSelect');
      const btn    = document.getElementById('updateStatusBtn');
      const status = select.value;

      if (status === '<%= order.status %>') {
        Swal.fire({ icon: 'info', text: 'Status is already ' + status, timer: 1500, showConfirmButton: false });
        return;
      }

      if (status === 'Cancelled') {
        const confirm = await Swal.fire({
          icon: 'warning',
          title: 'Cancel this order?',
          text: 'Stock will be restored. This cannot be undone.',
          showCancelButton: true,
          confirmButtonColor: '#ef4444',
          confirmButtonText: 'Yes, cancel it'
        });
        if (!confirm.isConfirmed) return;
      }

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Saving…';

      try {
        const res  = await fetch(`/admin/orders/${ORDER_ID}/status`, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ status })
        });
        const data = await res.json();
        if (data.success) {
          await Swal.fire({ icon: 'success', text: data.message, timer: 1500, showConfirmButton: false });
          location.reload();
        } else {
          Swal.fire({ icon: 'error', text: data.message || 'Update failed' });
        }
      } catch (e) {
        Swal.fire({ icon: 'error', text: 'Network error. Please try again.' });
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save me-1"></i> Save Status';
      }
    }

    async function handleReturn(action) {
      const label  = action === 'approve' ? 'Approve Return' : 'Reject Return';
      const colour = action === 'approve' ? '#16a34a' : '#ef4444';
      const text   = action === 'approve'
        ? 'Stock will be restored and order marked as Returned.'
        : 'Order will revert to Delivered status.';

      const result = await Swal.fire({
        title: label + '?',
        text,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: colour,
        confirmButtonText: label
      });
      if (!result.isConfirmed) return;

      try {
        const res  = await fetch(`/admin/orders/${ORDER_ID}/return`, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ action })
        });
        const data = await res.json();
        if (data.success) {
          await Swal.fire({ icon: 'success', text: data.message, timer: 1500, showConfirmButton: false });
          location.reload();
        } else {
          Swal.fire({ icon: 'error', text: data.message || 'Action failed' });
        }
      } catch (e) {
        Swal.fire({ icon: 'error', text: 'Network error. Please try again.' });
      }
    }
  </script>

