<%- include("../partials/user/header") %>

    <style>
        body {
            background-color: #f4f7f6;
            font-family: 'Inter', sans-serif;
        }

        .profile-layout {
            display: flex;
            justify-content: flex-start;
            max-width: 1200px;
            margin: 40px auto;
            gap: 30px;
            padding: 0 20px;
        }

        .sidebar-container {
            flex: 0 0 280px;
        }

        .form-container-box {
            flex: 1;
            background: #fff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }

        .form-title {
            color: #5b3f64;
            font-weight: 700;
            margin-bottom: 30px;
        }

        .input-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 15px;
        }

        .input-full {
            grid-column: 1 / -1;
        }

        .form-label {
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
            display: block;
            font-size: 14px;
        }

        .required::after {
            content: " *";
            color: #ff0101;
        }

        .form-control,
        .form-select {
            border: 1px solid #dce0e4;
            border-radius: 8px;
            padding: 10px 15px;
            width: 100%;
            font-size: 14px;
            transition: border-color 0.2s;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #5b3f64;
            outline: none;
            box-shadow: 0 0 0 3px rgba(91, 63, 100, 0.1);
        }

        .form-control[readonly] {
            background-color: #f8f9fa;
            color: #555;
            cursor: not-allowed;
        }

        textarea.form-control {
            resize: vertical;
            min-height: 90px;
        }

        .pincode-wrapper {
            position: relative;
        }

        .pincode-spinner {
            display: none;
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            border: 2px solid #ddd;
            border-top-color: #5b3f64;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        @keyframes spin {
            to {
                transform: translateY(-50%) rotate(360deg);
            }
        }

        .pincode-status {
            font-size: 12px;
            margin-top: 5px;
            min-height: 16px;
        }

        .pincode-status.success {
            color: #28a745;
        }

        .pincode-status.error {
            color: #dc3545;
        }

        .form-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 30px;
        }

        .btn-save {
            background-color: #000;
            color: white;
            border: none;
            padding: 10px 30px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-cancel {
            background-color: #f8f9fa;
            color: #333;
            border: 1px solid #ddd;
            padding: 10px 30px;
            border-radius: 6px;
            text-decoration: none;
        }
    </style>

    <div class="profile-layout">
        <div class="sidebar-container">
            <%- include('../partials/user/profileSidebar', { activePage: 'address' }) %>
        </div>

        <div class="form-container-box">
            <h4 class="form-title">Add New Address</h4>

            <form id="addAddressForm">


                <div class="input-grid">
                    <div>
                        <label class="form-label required">Full Name</label>
                        <input type="text" name="name" class="form-control" placeholder="Enter full name" required>
                    </div>
                    <div>
                        <label class="form-label required">Phone Number</label>
                        <input type="tel" name="phone" class="form-control" placeholder="10-digit mobile number"
                            required>
                    </div>
                </div>


                <div class="input-grid">
                    <div>
                        <label class="form-label required">Pincode</label>
                        <div class="pincode-wrapper">
                            <input type="text" name="pinCode" id="pinCode" class="form-control"
                                placeholder="6-digit pincode" maxlength="6" required>
                            <span class="pincode-spinner" id="pincodeSpinner"></span>
                        </div>
                        <div class="pincode-status" id="pincodeStatus"></div>
                    </div>
                    <div>
                        <label class="form-label">Locality</label>
                        <input type="text" name="locality" id="locality" class="form-control"
                            placeholder="Auto-filled from pincode" readonly>
                    </div>
                </div>


                <div class="input-grid">
                    <div>
                        <label class="form-label required">City / District</label>
                        <input type="text" name="city" id="city" class="form-control"
                            placeholder="Auto-filled from pincode" readonly required>
                    </div>
                    <div>
                        <label class="form-label required">State</label>
                        <select name="state" id="state" class="form-select" required>
                            <option value="">-- Select state --</option>
                            <option value="Andhra Pradesh">Andhra Pradesh</option>
                            <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                            <option value="Assam">Assam</option>
                            <option value="Bihar">Bihar</option>
                            <option value="Chhattisgarh">Chhattisgarh</option>
                            <option value="Goa">Goa</option>
                            <option value="Gujarat">Gujarat</option>
                            <option value="Haryana">Haryana</option>
                            <option value="Himachal Pradesh">Himachal Pradesh</option>
                            <option value="Jharkhand">Jharkhand</option>
                            <option value="Karnataka">Karnataka</option>
                            <option value="Kerala">Kerala</option>
                            <option value="Madhya Pradesh">Madhya Pradesh</option>
                            <option value="Maharashtra">Maharashtra</option>
                            <option value="Manipur">Manipur</option>
                            <option value="Meghalaya">Meghalaya</option>
                            <option value="Mizoram">Mizoram</option>
                            <option value="Nagaland">Nagaland</option>
                            <option value="Odisha">Odisha</option>
                            <option value="Punjab">Punjab</option>
                            <option value="Rajasthan">Rajasthan</option>
                            <option value="Sikkim">Sikkim</option>
                            <option value="Tamil Nadu">Tamil Nadu</option>
                            <option value="Telangana">Telangana</option>
                            <option value="Tripura">Tripura</option>
                            <option value="Uttar Pradesh">Uttar Pradesh</option>
                            <option value="Uttarakhand">Uttarakhand</option>
                            <option value="West Bengal">West Bengal</option>
                            <option value="Andaman and Nicobar Islands">Andaman and Nicobar Islands</option>
                            <option value="Chandigarh">Chandigarh</option>
                            <option value="Dadra and Nagar Haveli and Daman and Diu">Dadra and Nagar Haveli and Daman
                                and Diu</option>
                            <option value="Delhi">Delhi</option>
                            <option value="Jammu and Kashmir">Jammu and Kashmir</option>
                            <option value="Ladakh">Ladakh</option>
                            <option value="Lakshadweep">Lakshadweep</option>
                            <option value="Puducherry">Puducherry</option>
                        </select>
                    </div>
                </div>


                <div class="input-grid">
                    <div>
                        <label class="form-label required">Landmark / Area</label>
                        <input type="text" name="landMark" class="form-control" placeholder="e.g. Near City Mall"
                            required>
                    </div>

                    <div></div>
                </div>


                <div class="input-grid">
                    <div class="input-full">
                        <label class="form-label required">Address</label>
                        <textarea name="address" class="form-control"
                            placeholder="House No. / Flat No., Street Name, Building / Colony name..."
                            required></textarea>
                    </div>
                </div>

                <!-- Footer -->
                <div class="form-footer">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-save">Save Address</button>
                        <a href="/address" class="btn-cancel">Cancel</a>
                    </div>

                    <div class="d-flex gap-3 align-items-center">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="addressType" id="home" value="Home"
                                checked>
                            <label class="form-check-label" for="home">Home</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="addressType" id="work" value="Work">
                            <label class="form-check-label" for="work">Work</label>
                        </div>
                    </div>
                </div>

            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ─── Pincode Auto-fill ────────────────────────────────────────────────────
        const pincodeInput = document.getElementById('pinCode');
        const cityInput = document.getElementById('city');
        const stateSelect = document.getElementById('state');
        const localityInput = document.getElementById('locality');
        const spinner = document.getElementById('pincodeSpinner');
        const statusEl = document.getElementById('pincodeStatus');

        pincodeInput.addEventListener('input', async function () {
            const pin = this.value.trim();

            // Reset fields
            cityInput.value = '';
            stateSelect.value = '';
            localityInput.value = '';
            statusEl.textContent = '';
            statusEl.className = 'pincode-status';

            if (pin.length !== 6 || !/^\d{6}$/.test(pin)) return;

            spinner.style.display = 'block';

            try {
                const res = await fetch(`https://api.postalpincode.in/pincode/${pin}`);
                const data = await res.json();

                if (data[0].Status === 'Success' && data[0].PostOffice.length > 0) {
                    const po = data[0].PostOffice[0];

                    // Fill city (District)
                    cityInput.value = po.District || '';

                    // Fill locality (first post office name)
                    localityInput.value = po.Name || '';

                    // Select matching state in dropdown
                    const stateValue = po.State || '';
                    const option = Array.from(stateSelect.options)
                        .find(o => o.value.toLowerCase() === stateValue.toLowerCase());
                    if (option) stateSelect.value = option.value;

                    statusEl.textContent = '✓ Location found';
                    statusEl.className = 'pincode-status success';
                } else {
                    statusEl.textContent = '✗ Invalid pincode';
                    statusEl.className = 'pincode-status error';
                }
            } catch (err) {
                statusEl.textContent = '✗ Could not fetch pincode data';
                statusEl.className = 'pincode-status error';
            } finally {
                spinner.style.display = 'none';
            }
        });

        // ─── Form Submit ──────────────────────────────────────────────────────────
        document.getElementById("addAddressForm").addEventListener('submit', async (event) => {
            event.preventDefault();

            const formData = new FormData(event.target);
            const data = Object.fromEntries(formData.entries());

            const nameRegex = /^[a-zA-Z\s]{3,50}$/;
            const phoneRegex = /^[6-9]\d{9}$/;
            const pincodeRegex = /^\d{6}$/;

            if (!nameRegex.test(data.name.trim())) {
                return Swal.fire({ icon: "warning", title: "Invalid Name", text: "Name must be 3–50 letters only." });
            }
            if (!phoneRegex.test(data.phone.trim())) {
                return Swal.fire({ icon: "warning", title: "Invalid Phone", text: "Enter a valid 10-digit Indian mobile number." });
            }
            if (!pincodeRegex.test(data.pinCode.trim())) {
                return Swal.fire({ icon: "warning", title: "Invalid Pincode", text: "Pincode must be exactly 6 digits." });
            }
            if (!data.city || !data.city.trim()) {
                return Swal.fire({ icon: "warning", title: "Missing Field", text: "Please enter a valid pincode to auto-fill City." });
            }
            if (!data.state || !data.state.trim()) {
                return Swal.fire({ icon: "warning", title: "Missing Field", text: "Please select a State." });
            }
            if (!data.landMark.trim()) {
                return Swal.fire({ icon: "warning", title: "Missing Field", text: "Landmark / Area is required." });
            }
            if (!data.address || !data.address.trim()) {
                return Swal.fire({ icon: "warning", title: "Missing Field", text: "Detailed Address is required." });
            }

            try {
                const response = await fetch('/addAddress', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: "success",
                        title: "Saved!",
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = "/address";
                    });
                } else {
                    Swal.fire({ icon: "error", title: "Failed", text: result.message || "Error saving" });
                }
            } catch (error) {
                Swal.fire({ icon: "error", title: "Error", text: "Server error. Please try again." });
            }
        });
    </script>