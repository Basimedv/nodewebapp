<%- include("../partials/user/header") %>

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
  .cart-wrapper {
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 20px;
  }

  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 30px;
    padding-bottom: 15px;
    border-bottom: 2px solid #f0f0f0;
  }

  .cart-header h2 {
    font-size: 1.8rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
  }

  .cart-count {
    font-size: 0.9rem;
    color: #666;
    background: #f0f0f0;
    padding: 4px 12px;
    border-radius: 20px;
  }

  /* Layout */
  .cart-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 30px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .cart-layout { grid-template-columns: 1fr; }
  }

  /* Cart Items */
  .cart-items { display: flex; flex-direction: column; gap: 16px; }

  .cart-card {
    background: white;
    border-radius: 12px;
    padding: 16px;
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 16px;
    align-items: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: box-shadow 0.2s;
  }

  .cart-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); }

  .cart-card-img {
    width: 100px;
    height: 120px;
    border-radius: 8px;
    overflow: hidden;
    background: #f5f5f5;
  }

  .cart-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-card-info { flex: 1; }

  .cart-product-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 6px;
    text-decoration: none;
    display: block;
  }

  .cart-product-name:hover { color: #555; }

  .cart-meta {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 10px;
  }

  .cart-meta span {
    background: #f0f0f0;
    padding: 2px 8px;
    border-radius: 4px;
    margin-right: 6px;
  }

  .cart-price {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 10px;
  }

  /* Quantity control */
  .qty-control {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid #ddd;
    border-radius: 6px;
    overflow: hidden;
    width: fit-content;
  }

  .qty-btn {
    width: 32px;
    height: 32px;
    border: none;
    background: #f5f5f5;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    color: #333;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .qty-btn:hover:not(:disabled) { background: #e0e0e0; }
  .qty-btn:disabled { color: #ccc; cursor: not-allowed; }

  .qty-value {
    width: 40px;
    height: 32px;
    text-align: center;
    border: none;
    border-left: 1px solid #ddd;
    border-right: 1px solid #ddd;
    font-size: 0.9rem;
    font-weight: 600;
    background: white;
  }

  /* Item total */
  .cart-card-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  .item-total {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .btn-remove-item {
    background: none;
    border: none;
    color: #bbb;
    cursor: pointer;
    font-size: 1rem;
    padding: 4px;
    transition: color 0.2s;
  }

  .btn-remove-item:hover { color: #e53935; }

  /* Order Summary */
  .order-summary {
    background: white;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    position: sticky;
    top: 20px;
  }

  .order-summary h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f0f0f0;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    font-size: 0.9rem;
    color: #555;
  }

  .summary-row.total {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    padding-top: 12px;
    margin-top: 8px;
    border-top: 2px solid #f0f0f0;
    margin-bottom: 20px;
  }

  .summary-row .savings {
    color: #2e7d32;
    font-weight: 600;
  }

  .btn-checkout {
    width: 100%;
    padding: 14px;
    background: #1a1a1a;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
  }

  .btn-checkout:hover { background: #333; transform: translateY(-1px); color: white; }

  .btn-continue {
    display: block;
    text-align: center;
    margin-top: 12px;
    color: #666;
    font-size: 0.85rem;
    text-decoration: none;
  }

  .btn-continue:hover { color: #1a1a1a; }

  /* Empty cart */
  .empty-cart {
    text-align: center;
    padding: 80px 20px;
    grid-column: 1 / -1;
  }

  .empty-cart i {
    font-size: 4rem;
    color: #ddd;
    margin-bottom: 20px;
    display: block;
  }

  .empty-cart h3 { font-size: 1.4rem; color: #666; margin-bottom: 10px; }
  .empty-cart p  { color: #999; margin-bottom: 24px; }

  .btn-shop {
    display: inline-block;
    padding: 12px 32px;
    background: #1a1a1a;
    color: white;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s;
  }

  .btn-shop:hover { background: #333; color: white; }

  @media (max-width: 600px) {
    .cart-card {
      grid-template-columns: 80px 1fr;
    }
    .cart-card-right {
      grid-column: 1 / -1;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>

<main>
  <div class="cart-wrapper">

    <div class="cart-header">
      <h2>My Cart</h2>
      <span class="cart-count" id="cart-count">
        <%= cartItems.length %> item<%= cartItems.length !== 1 ? 's' : '' %>
      </span>
    </div>

    <% if (cartItems && cartItems.length > 0) { %>
    <div class="cart-layout">

      <!-- LEFT: Cart Items -->
      <div class="cart-items" id="cart-items-container">
        <% cartItems.forEach(item => { %>
          <div class="cart-card" id="cart-item-<%= item._id %>">

            <!-- Image -->
            <div class="cart-card-img">
              <a href="/productDetails/<%= item.productId %>">
                <img src="<%= item.image %>" alt="<%= item.productName %>">
              </a>
            </div>

            <!-- Info -->
            <div class="cart-card-info">
              <a href="/productDetails/<%= item.productId %>" class="cart-product-name">
                <%= item.productName %>
              </a>
              <div class="cart-meta">
                <span>Size: <%= item.size %></span>
                <% if (item.stock < 5 && item.stock > 0) { %>
                  <span style="color:#e65100; background:#fff3e0;">Only <%= item.stock %> left</span>
                <% } %>
              </div>
              <div class="cart-price">₹<%= item.price.toLocaleString('en-IN') %></div>

              <!-- Quantity -->
              <div class="qty-control">
                <button class="qty-btn"
                  onclick="updateQty('<%= item._id %>', <%= item.quantity - 1 %>, <%= item.stock %>)"
                  <%= item.quantity <= 1 ? 'disabled' : '' %>>−</button>
                <input class="qty-value" type="text"
                  value="<%= item.quantity %>"
                  id="qty-<%= item._id %>"
                  readonly>
                <button class="qty-btn"
                  onclick="updateQty('<%= item._id %>', <%= item.quantity + 1 %>, <%= item.stock %>)"
                  <%= item.quantity >= 10 || item.quantity >= item.stock ? 'disabled' : '' %>>+</button>
              </div>
            </div>

            <!-- Right: total + remove -->
            <div class="cart-card-right">
              <div class="item-total" id="item-total-<%= item._id %>">
                ₹<%= (item.price * item.quantity).toLocaleString('en-IN') %>
              </div>
              <button class="btn-remove-item" onclick="removeItem('<%= item._id %>')" title="Remove">
                <i class="fas fa-trash-alt"></i>
              </button>
            </div>

          </div>
        <% }) %>
      </div>

      <!-- RIGHT: Order Summary -->
      <div class="order-summary">
        <h3>Order Summary</h3>

        <%
          const totalMRP     = cartItems.reduce((s, i) => s + i.price * i.quantity, 0);
          const totalSavings = 0; // add coupon/discount logic later
          const delivery     = 0; // free delivery
          const finalTotal   = totalMRP - totalSavings + delivery;
        %>

        <div class="summary-row">
          <span>Subtotal (<%= cartItems.length %> items)</span>
          <span id="summary-subtotal">₹<%= totalMRP.toLocaleString('en-IN') %></span>
        </div>

        <% if (totalSavings > 0) { %>
        <div class="summary-row">
          <span>Discount</span>
          <span class="savings">− ₹<%= totalSavings.toLocaleString('en-IN') %></span>
        </div>
        <% } %>

        <div class="summary-row">
          <span>Delivery</span>
          <span style="color:#2e7d32; font-weight:600;">
            <%= delivery === 0 ? 'FREE' : '₹' + delivery %>
          </span>
        </div>

        <div class="summary-row total">
          <span>Total</span>
          <span id="summary-total">₹<%= finalTotal.toLocaleString('en-IN') %></span>
        </div>

        <a href="/checkout" class="btn-checkout">
          <i class="fas fa-lock"></i> Proceed to Checkout
        </a>
        <a href="/shop" class="btn-continue">← Continue Shopping</a>
      </div>

    </div>

    <% } else { %>
      <!-- Empty Cart -->
      <div class="empty-cart">
        <i class="fas fa-shopping-cart"></i>
        <h3>Your cart is empty</h3>
        <p>Looks like you haven't added anything yet.</p>
        <a href="/shop" class="btn-shop">Start Shopping</a>
      </div>
    <% } %>

  </div>
</main>

<%- include("../partials/user/footer") %>

<script>
  // ── UPDATE QUANTITY ──────────────────────────────────────────
  async function updateQty(itemId, newQty, stock) {
    if (newQty < 1 || newQty > 10 || newQty > stock) return;

    try {
      const res  = await fetch('/cart/update', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ itemId, quantity: newQty })
      });
      const data = await res.json();

      if (data.success) {
        // Update qty display
        document.getElementById(`qty-${itemId}`).value = newQty;

        // Update item total
        const itemTotalEl = document.getElementById(`item-total-${itemId}`);
        if (itemTotalEl) {
          itemTotalEl.textContent = '₹' + data.itemTotal.toLocaleString('en-IN');
        }

        // Update summary
        document.getElementById('summary-subtotal').textContent =
          '₹' + data.cartSubtotal.toLocaleString('en-IN');
        document.getElementById('summary-total').textContent =
          '₹' + data.cartSubtotal.toLocaleString('en-IN');

        // Reload to refresh button states cleanly
        location.reload();
      } else {
        Swal.fire({ icon: 'warning', text: data.message, timer: 1500, showConfirmButton: false });
      }
    } catch (err) {
      console.error('updateQty error:', err);
      Swal.fire({ icon: 'error', text: 'Network error. Please try again.', timer: 1500, showConfirmButton: false });
    }
  }

  // ── REMOVE ITEM ──────────────────────────────────────────────
  async function removeItem(itemId) {
    const result = await Swal.fire({
      title: 'Remove item?',
      text:  'This item will be removed from your cart.',
      icon:  'question',
      showCancelButton:     true,
      confirmButtonColor:   '#1a1a1a',
      cancelButtonColor:    '#aaa',
      confirmButtonText:    'Yes, Remove',
      cancelButtonText:     'Cancel'
    });

    if (!result.isConfirmed) return;

    try {
      const res  = await fetch('/cart/remove', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ itemId })
      });
      const data = await res.json();

      if (data.success) {
        // Animate out
        const card = document.getElementById(`cart-item-${itemId}`);
        if (card) {
          card.style.transition = 'opacity 0.3s, transform 0.3s';
          card.style.opacity    = '0';
          card.style.transform  = 'translateX(20px)';
          setTimeout(() => {
            card.remove();
            updateSummaryUI(data.cartSubtotal);
          }, 300);
        }

        Swal.fire({ icon: 'success', text: 'Item removed', timer: 1000, showConfirmButton: false });
      } else {
        Swal.fire({ icon: 'error', text: data.message, timer: 1500, showConfirmButton: false });
      }
    } catch (err) {
      Swal.fire({ icon: 'error', text: 'Network error. Please try again.', timer: 1500, showConfirmButton: false });
    }
  }

  // ── UPDATE SUMMARY UI ────────────────────────────────────────
  function updateSummaryUI(subtotal) {
    const remaining = document.querySelectorAll('.cart-card').length;

    // Update count
    const countEl = document.getElementById('cart-count');
    if (countEl) {
      countEl.textContent = `${remaining} item${remaining !== 1 ? 's' : ''}`;
    }

    // Update totals
    const subtotalEl = document.getElementById('summary-subtotal');
    const totalEl    = document.getElementById('summary-total');
    if (subtotalEl) subtotalEl.textContent = '₹' + subtotal.toLocaleString('en-IN');
    if (totalEl)    totalEl.textContent    = '₹' + subtotal.toLocaleString('en-IN');

    // Show empty state
    if (remaining === 0) {
      document.querySelector('.cart-layout').innerHTML = `
        <div class="empty-cart" style="grid-column:1/-1">
          <i class="fas fa-shopping-cart"></i>
          <h3>Your cart is empty</h3>
          <p>Looks like you haven't added anything yet.</p>
          <a href="/shop" class="btn-shop">Start Shopping</a>
        </div>`;
    }
  }
</script>