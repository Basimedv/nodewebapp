<%- include("../partials/user/header") %>

  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #f5f5f5;
      font-family: 'Inter', sans-serif;
    }

    .page-wrapper {
      display: flex;
      min-height: 100vh;
    }

    .sidebar-container {
      width: 280px;
      flex-shrink: 0;
    }

    .content-wrapper {
      flex: 1;
      padding: 40px 50px;
      min-width: 0;
    }

    .main-content-area {
      background: #fff;
      padding: 50px;
      border-radius: 20px;
      box-shadow: 0 4px 25px rgba(0, 0, 0, 0.05);
      max-width: 750px;
    }

    .choice-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 40px;
    }

    .choice-card {
      padding: 20px;
      border: 1px solid #e0e0e0;
      border-radius: 12px;
      cursor: pointer;
      text-align: center;
      background: #fdfdfd;
      font-weight: 600;
      transition: 0.3s;
    }

    .choice-card.active {
      background: #000;
      color: #fff;
      border-color: #000;
    }

    .settings-form-container {
      display: none;
      animation: fadeIn 0.3s ease;
    }

    .settings-form-container.active {
      display: block;
    }

    .form-group-row {
      display: grid;
      grid-template-columns: 30% 70%;
      align-items: center;
      margin-bottom: 25px;
    }

    .label-cell {
      font-weight: 600;
      color: #333;
    }

    .input-cell input {
      width: 100%;
      padding: 14px;
      border: 1px solid #e0e0e0;
      border-radius: 10px;
      font-size: 14px;
      background: #fcfcfc;
    }

    .button-alignment-row {
      display: grid;
      grid-template-columns: 30% 70%;
      margin-top: 10px;
    }

    .btn-submit {
      grid-column: 2;
      background: #000;
      color: #fff;
      border: none;
      padding: 14px 40px;
      border-radius: 10px;
      font-weight: 600;
      cursor: pointer;
      width: fit-content;
    }

    .btn-submit:disabled {
      background: #666;
      cursor: not-allowed;
    }

    .password-wrapper {
      position: relative;
    }

    .password-wrapper input {
      padding-right: 45px;
    }

    .eye-icon {
      position: absolute;
      right: 15px;
      top: 50%;
      transform: translateY(-50%);
      cursor: pointer;
      color: #666;
      font-size: 18px;
    }

    .eye-icon:hover {
      color: #000;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }

      to {
        opacity: 1;
      }
    }
  </style>

  <div class="page-wrapper">
    <div class="sidebar-container">
      <%- include('../partials/user/profileSidebar', { activePage: 'privacy' }) %>
    </div>

    <div class="content-wrapper">
      <div class="main-content-area">
        <h4 class="fw-bold mb-4">Privacy & Security</h4>

        <% if (isGoogleUser) { %>
          <div class="text-center py-5">
            <img src="https://cdn-icons-png.flaticon.com/512/300/300221.png" style="width:60px;" class="mb-4">
            <h5 class="fw-bold">Google Login Active</h5>
            <p class="text-muted">Passwords and emails are managed via Google.</p>
            <a href="/profile" class="btn btn-dark mt-2">Back to Profile</a>
          </div>
          <% } else { %>

            <div class="choice-grid">
              <div class="choice-card active" onclick="switchTab('email-sec', this)">Update Email</div>
              <div class="choice-card" onclick="switchTab('pass-sec', this)">Change Password</div>
            </div>

            <!-- EMAIL SECTION -->
            <div id="email-sec" class="settings-form-container active">
              <div class="form-group-row">
                <div class="label-cell">Current Email</div>
                <div class="input-cell">
                  <input type="text" value="<%= user.email %>" disabled style="opacity:0.6;">
                </div>
              </div>
              <div class="form-group-row">
                <div class="label-cell">New Email</div>
                <div class="input-cell">
                  <input type="email" id="emailInp" placeholder="Enter new email address">
                </div>
              </div>
              <div class="button-alignment-row">
                <button onclick="sendEmailOtp()" class="btn-submit" id="sendOtpBtn">Send OTP</button>
              </div>
            </div>

            <!-- PASSWORD SECTION -->
            <div id="pass-sec" class="settings-form-container">
              <div class="form-group-row">
                <div class="label-cell">Current Password</div>
                <div class="input-cell password-wrapper">
                  <input type="password" id="curPass" placeholder="••••••••">
                  <i class="fa-solid fa-eye eye-icon" onclick="togglePassword('curPass', this)"></i>
                </div>
              </div>
              <div class="button-alignment-row">
                <button onclick="verifyCurrent()" class="btn-submit" id="verifyPwdBtn">Continue</button>
              </div>
            </div>

            <% } %>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    function switchTab(id, el) {
      document.querySelectorAll('.choice-card').forEach(c => c.classList.remove('active'));
      document.querySelectorAll('.settings-form-container').forEach(s => s.classList.remove('active'));
      el.classList.add('active');
      document.getElementById(id).classList.add('active');
    }

    // EMAIL FLOW — send OTP then redirect to OTP page
    async function sendEmailOtp() {
      const newEmail = document.getElementById('emailInp').value.trim();

      if (!newEmail) return Swal.fire('Error', 'Please enter your new email address.', 'error');

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(newEmail)) return Swal.fire('Error', 'Please enter a valid email address.', 'error');

      const btn = document.getElementById('sendOtpBtn');
      btn.disabled = true;
      btn.textContent = 'Sending...';

      try {
        const res = await fetch('/change-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ newEmail })
        });
        const data = await res.json();

        if (data.success) {
          Swal.fire({
            icon: 'success', title: 'OTP Sent!',
            text: 'Check your new email for the OTP.',
            timer: 1500, showConfirmButton: false
          }).then(() => {
            window.location.href = data.redirect;
          });
        } else {
          btn.disabled = false;
          btn.textContent = 'Send OTP';
          Swal.fire('Error', data.message, 'error');
        }
      } catch (err) {
        btn.disabled = false;
        btn.textContent = 'Send OTP';
        Swal.fire('Error', 'Could not connect to server.', 'error');
      }
    }


    async function verifyCurrent() {
      const currentPassword = document.getElementById('curPass').value;
      if (!currentPassword) return Swal.fire('Error', 'Please enter your current password.', 'error');

      const btn = document.getElementById('verifyPwdBtn');
      btn.disabled = true;
      btn.textContent = 'Verifying...';

      try {
        const res = await fetch('/verify-current-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ currentPassword })
        });
        const data = await res.json();

        if (data.success) {
          Swal.fire({
            icon: 'success', title: 'Verified!',
            text: 'Redirecting to change password...',
            timer: 1200, showConfirmButton: false
          }).then(() => {
            window.location.href = data.redirect;
          });
        } else {
          btn.disabled = false;
          btn.textContent = 'Continue';
          Swal.fire('Error', data.message, 'error');
        }
      } catch (err) {
        btn.disabled = false;
        btn.textContent = 'Continue';
        Swal.fire('Error', 'Could not connect to server.', 'error');
      }
    }

    function togglePassword(inputId, icon) {
      const input = document.getElementById(inputId);
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }
  </script>

  <%- include("../partials/user/footer") %>